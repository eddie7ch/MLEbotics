{
  "name": "mlebotics",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./dev-all.ps1",
    "build": "node ./tools/run-workspace-workflow.mjs build",
    "start": "powershell -ExecutionPolicy Bypass -File ./tools/start-all.ps1",
    "lint": "node ./tools/run-workspace-workflow.mjs lint",
    "typecheck": "node ./tools/run-workspace-workflow.mjs typecheck",
    "dev:marketing": "node ./apps/marketing/node_modules/astro/astro.js dev --root ./apps/marketing --host --port 54321",
    "dev:console": "node ./apps/console/node_modules/next/dist/bin/next dev ./apps/console --hostname 0.0.0.0 --port 3001",
    "dev:studio": "node ./apps/studio/node_modules/next/dist/bin/next dev ./apps/studio --hostname 0.0.0.0 --port 3002",
    "dev:docs": "node ./apps/docs/node_modules/next/dist/bin/next dev ./apps/docs --hostname 0.0.0.0 --port 3003",
    "build:marketing": "node ./apps/marketing/node_modules/astro/astro.js build --root ./apps/marketing",
    "build:console": "node ./apps/console/node_modules/next/dist/bin/next build ./apps/console",
    "build:studio": "node ./apps/studio/node_modules/next/dist/bin/next build ./apps/studio",
    "build:docs": "node ./apps/docs/node_modules/next/dist/bin/next build ./apps/docs",
    "start:marketing": "node ./apps/marketing/node_modules/astro/astro.js preview --root ./apps/marketing --host --port 54321",
    "start:console": "node ./apps/console/node_modules/next/dist/bin/next start ./apps/console --hostname 0.0.0.0 --port 3001",
    "start:studio": "node ./apps/studio/node_modules/next/dist/bin/next start ./apps/studio --hostname 0.0.0.0 --port 3002",
    "start:docs": "node ./apps/docs/node_modules/next/dist/bin/next start ./apps/docs --hostname 0.0.0.0 --port 3003"
  },
  "devDependencies": {
    "next": "^15.5.14",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
