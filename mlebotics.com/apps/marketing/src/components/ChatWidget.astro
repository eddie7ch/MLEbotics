---
// ChatWidget.astro — persistent floating community chat on every page
---

<!-- Community Chat Floating Widget -->
<div id="chat-widget" class="chat-widget" hidden>
  <div class="chat-panel" id="chat-panel" hidden>
    <div class="chat-panel__header">
      <span class="chat-panel__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Community Chat
        <span class="chat-panel__badge">Live</span>
      </span>
      <div style="display:flex;align-items:center;gap:.25rem;">
        <button id="min-chat" class="chat-close" aria-label="Minimise chat" title="Minimise">&#x2013;</button>
        <button id="close-chat" class="chat-close" aria-label="Close chat" title="Close" style="font-size:1.2rem;">&times;</button>
      </div>
    </div>
    <!-- Name entry screen -->
    <div id="chat-name-screen" style="display:none;padding:1.5rem 1.25rem;">
      <div style="text-align:center;margin-bottom:1rem;">
        <div style="font-size:2rem;">👋</div>
        <p style="color:#fff;font-weight:600;font-size:.95rem;margin:.4rem 0 .2rem;">What should we call you?</p>
        <p style="color:#6b7280;font-size:.75rem;">Your name shows next to your messages.</p>
      </div>
      <input id="chat-name-input" type="text" maxlength="30" placeholder="Enter your name…" autocomplete="off"
        style="width:100%;box-sizing:border-box;background:#1f2937;border:1px solid #374151;color:#f3f4f6;border-radius:8px;padding:.6rem .75rem;font-size:.85rem;outline:none;margin-bottom:.75rem;" />
      <div style="display:flex;gap:.5rem;" id="chat-name-btns">
        <button id="chat-name-save" style="flex:1;background:#06b6d4;border:none;color:#030712;font-weight:700;font-size:.85rem;border-radius:8px;padding:.6rem;cursor:pointer;">Join Chat</button>
      </div>
    </div>
    <!-- Name bar (shown after name is set) -->
    <div id="chat-name-bar" style="display:none;border-bottom:1px solid #1f2937;padding:.4rem 1rem;display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,.2);">
      <span style="font-size:.7rem;color:#6b7280;">Chatting as <strong id="chat-name-display" style="color:#22d3ee;"></strong></span>
      <button id="chat-name-edit" style="background:none;border:none;color:#6b7280;font-size:.7rem;cursor:pointer;padding:0;">✏️ Edit</button>
    </div>
    <div class="chat-messages" id="chat-messages">
      <div style="display:flex;flex-direction:column;align-items:flex-start;margin-bottom:.75rem;">
        <span style="font-size:.65rem;font-weight:600;margin-bottom:.2rem;padding:0 .2rem;color:#9ca3af;">MLEbotics</span>
        <div style="max-width:78%;border-radius:1rem;border-top-left-radius:.2rem;padding:.45rem .75rem;font-size:.85rem;line-height:1.5;background:#1f2937;color:#f3f4f6;">
          👋 Welcome to MLEbotics Community Chat! Ask questions, share what you're building, or just say hi.
        </div>
      </div>
    </div>
    <div class="chat-input-row" id="chat-input-row">
      <input id="chat-input" type="text" placeholder="Type a message…" class="chat-input" autocomplete="off" />
      <button id="chat-send" class="chat-send-btn" aria-label="Send">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>

  <!-- FAB with dismiss button -->
  <div style="position:relative;display:inline-flex;align-items:center;">
    <button id="chat-fab" class="chat-fab" aria-label="Community chat">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Community
    </button>
    <button id="chat-dismiss" aria-label="Dismiss chat" title="Hide chat"
      style="position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:#374151;border:1px solid #4b5563;color:#9ca3af;font-size:.7rem;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;">
      &times;
    </button>
  </div>
</div>

<script is:inline>
(function () {
  const FIREBASE_CFG = {
    apiKey: 'AIzaSyDTJWhkRNMa5lOSdwxGLUGrpvWXrLuljfc',
    authDomain: 'running-companion-a935f.firebaseapp.com',
    projectId: 'running-companion-a935f',
    storageBucket: 'running-companion-a935f.firebasestorage.app',
    messagingSenderId: '618174257557',
    appId: '1:618174257557:web:29ca5df050bd6daae9be9c'
  };
  const LOCAL_DRAFT_KEY   = 'mlebotics_chat_draft';
  const LOCAL_NAME_KEY    = 'mlebotics_chat_name';
  const LOCAL_DISMISS_KEY = 'mlebotics_chat_dismissed';
  const LOCAL_OPEN_KEY    = 'mlebotics_chat_open';
  const FB_VER = '10.12.2';

  const widget    = document.getElementById('chat-widget');
  const panel     = document.getElementById('chat-panel');
  const fab       = document.getElementById('chat-fab');
  const dismissBtn = document.getElementById('chat-dismiss');
  const minBtn    = document.getElementById('min-chat');
  const closeBtn  = document.getElementById('close-chat');
  const input     = document.getElementById('chat-input');
  const sendBtn   = document.getElementById('chat-send');
  const msgs      = document.getElementById('chat-messages');
  const nameScreen  = document.getElementById('chat-name-screen');
  const nameBar     = document.getElementById('chat-name-bar');
  const nameInput   = document.getElementById('chat-name-input');
  const nameSaveBtn = document.getElementById('chat-name-save');
  const nameDisplay = document.getElementById('chat-name-display');
  const nameEditBtn = document.getElementById('chat-name-edit');
  const inputRow    = document.getElementById('chat-input-row');

  // Don't show if user dismissed it
  if (localStorage.getItem(LOCAL_DISMISS_KEY) === '1') return;
  widget.hidden = false;

  let currentName = localStorage.getItem(LOCAL_NAME_KEY) || '';
  input.value = localStorage.getItem(LOCAL_DRAFT_KEY) || '';
  input.addEventListener('input', () => localStorage.setItem(LOCAL_DRAFT_KEY, input.value));

  function formatTimestamp(seconds) {
    const d = new Date(seconds * 1000);
    const now = new Date();
    const isToday = d.toDateString() === now.toDateString();
    const time = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    return isToday ? 'Today · ' + time : d.toLocaleDateString([], { month: 'short', day: 'numeric' }) + ' · ' + time;
  }

  function showChatUI() {
    nameScreen.style.display = 'none';
    nameBar.style.display = 'flex';
    msgs.style.display = '';
    inputRow.style.display = '';
    nameDisplay.textContent = currentName;
    setTimeout(() => { input.focus(); msgs.scrollTop = msgs.scrollHeight; }, 50);
  }

  function showNameScreen(editing) {
    nameInput.value = editing ? currentName : '';
    nameInput.placeholder = editing ? 'Change your name…' : 'Enter your name…';
    nameSaveBtn.textContent = editing ? 'Save' : 'Join Chat';
    const btns = document.getElementById('chat-name-btns');
    if (editing) {
      if (!document.getElementById('chat-name-cancel')) {
        const cancelBtn = document.createElement('button');
        cancelBtn.id = 'chat-name-cancel';
        cancelBtn.textContent = 'Cancel';
        cancelBtn.style.cssText = 'flex:1;background:none;border:1px solid #374151;color:#9ca3af;font-size:.85rem;border-radius:8px;padding:.6rem;cursor:pointer;';
        cancelBtn.addEventListener('click', () => { document.getElementById('chat-name-cancel').remove(); showChatUI(); });
        btns.insertBefore(cancelBtn, nameSaveBtn);
      }
    } else {
      const c = document.getElementById('chat-name-cancel');
      if (c) c.remove();
    }
    nameScreen.style.display = '';
    nameBar.style.display = 'none';
    msgs.style.display = 'none';
    inputRow.style.display = 'none';
    setTimeout(() => nameInput.focus(), 50);
  }

  if (currentName) { showChatUI(); } else { showNameScreen(false); }

  function saveName() {
    const trimmed = nameInput.value.trim();
    if (!trimmed) return;
    currentName = trimmed;
    localStorage.setItem(LOCAL_NAME_KEY, currentName);
    const c = document.getElementById('chat-name-cancel');
    if (c) c.remove();
    showChatUI();
  }
  nameSaveBtn.addEventListener('click', saveName);
  nameInput.addEventListener('keydown', e => { if (e.key === 'Enter') saveName(); });
  nameEditBtn.addEventListener('click', () => showNameScreen(true));

  // Online/offline indicator
  let offlineBanner = null;
  function updateOnlineStatus() {
    if (!navigator.onLine) {
      if (!offlineBanner) {
        offlineBanner = document.createElement('div');
        offlineBanner.style.cssText = 'background:#b45309;color:#fff;font-size:.75rem;padding:.35rem .75rem;text-align:center;';
        offlineBanner.textContent = '⚠ Offline — messages will sync when reconnected';
        panel.insertBefore(offlineBanner, inputRow);
      }
    } else {
      if (offlineBanner) { offlineBanner.remove(); offlineBanner = null; }
    }
  }
  window.addEventListener('online', updateOnlineStatus);
  window.addEventListener('offline', updateOnlineStatus);
  updateOnlineStatus();

  let unreadCount = 0;
  function updateBadge() {
    let badge = fab.querySelector('.chat-badge');
    if (unreadCount > 0 && panel.hidden) {
      if (!badge) {
        badge = document.createElement('span');
        badge.className = 'chat-badge';
        badge.style.cssText = 'position:absolute;top:-4px;right:-4px;background:#ef4444;color:#fff;border-radius:99px;font-size:.65rem;min-width:16px;height:16px;display:flex;align-items:center;justify-content:center;padding:0 3px;';
        fab.style.position = 'relative';
        fab.appendChild(badge);
      }
      badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
    } else if (badge) { badge.remove(); }
  }

  function togglePanel(show) {
    panel.hidden = !show;
    localStorage.setItem(LOCAL_OPEN_KEY, show ? '1' : '0');
    if (show) {
      if (!currentName) showNameScreen(false);
      else showChatUI();
      unreadCount = 0;
      updateBadge();
    }
  }

  // Restore open state across pages
  if (localStorage.getItem(LOCAL_OPEN_KEY) === '1') togglePanel(true);

  fab.addEventListener('click', () => togglePanel(panel.hidden));
  // Minimise — close panel, keep FAB
  minBtn.addEventListener('click', () => togglePanel(false));
  // × on panel — same as minimise
  closeBtn.addEventListener('click', () => togglePanel(false));
  // Dismiss button on FAB — fully hides the whole widget
  dismissBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    localStorage.setItem(LOCAL_DISMISS_KEY, '1');
    localStorage.setItem(LOCAL_OPEN_KEY, '0');
    widget.hidden = true;
  });

  const renderedIds = new Set();
  function renderMsg(id, text, fromType, senderName, tsSeconds) {
    if (renderedIds.has(id)) return;
    renderedIds.add(id);
    const isMe = senderName && currentName && senderName === currentName;
    const wrapper = document.createElement('div');
    wrapper.id = 'cmsg-' + id;
    wrapper.style.cssText = 'display:flex;flex-direction:column;' + (isMe ? 'align-items:flex-end;' : 'align-items:flex-start;') + 'margin-bottom:.75rem;';

    const nameEl = document.createElement('span');
    nameEl.style.cssText = 'font-size:.65rem;font-weight:600;margin-bottom:.2rem;padding:0 .2rem;color:' + (isMe ? '#22d3ee' : '#9ca3af') + ';';
    nameEl.textContent = isMe ? 'You' : (senderName || 'Anonymous');
    wrapper.appendChild(nameEl);

    const bubble = document.createElement('div');
    bubble.style.cssText = 'max-width:78%;border-radius:1rem;padding:.45rem .75rem;font-size:.85rem;line-height:1.5;word-break:break-word;' +
      (isMe
        ? 'background:#06b6d4;color:#030712;border-top-right-radius:.2rem;'
        : 'background:#1f2937;color:#f3f4f6;border-top-left-radius:.2rem;');
    bubble.textContent = text;
    wrapper.appendChild(bubble);

    if (tsSeconds) {
      const tsEl = document.createElement('span');
      tsEl.style.cssText = 'font-size:.7rem;color:#9ca3af;margin-top:.2rem;padding:0 .2rem;';
      tsEl.textContent = formatTimestamp(tsSeconds);
      wrapper.appendChild(tsEl);
    }

    msgs.appendChild(wrapper);
    msgs.scrollTop = msgs.scrollHeight;
  }

  let sendMsgFn = null;

  import('https://www.gstatic.com/firebasejs/' + FB_VER + '/firebase-app.js').then(({ initializeApp, getApps }) => {
    const app = getApps().length === 0 ? initializeApp(FIREBASE_CFG) : getApps()[0];
    import('https://www.gstatic.com/firebasejs/' + FB_VER + '/firebase-firestore.js').then(({ getFirestore, enableIndexedDbPersistence, collection, addDoc, query, orderBy, limit, onSnapshot, serverTimestamp }) => {
      const db = getFirestore(app);
      enableIndexedDbPersistence(db).catch(() => {});
      const q = query(collection(db, 'community_chat'), orderBy('createdAt', 'asc'), limit(60));
      onSnapshot(q, snapshot => {
        snapshot.docChanges().forEach(change => {
          if (change.type === 'added') {
            const data = change.doc.data({ serverTimestamps: 'estimate' });
            renderMsg(change.doc.id, data.text, data.from || 'user', data.name, data.createdAt?.seconds ?? null);
            if (panel.hidden) { unreadCount++; updateBadge(); }
          }
        });
      });
      sendMsgFn = async (text) => {
        await addDoc(collection(db, 'community_chat'), { text, from: 'user', name: currentName || 'Anonymous', createdAt: serverTimestamp() });
      };
    });
  }).catch(() => {
    sendMsgFn = async (text) => { renderMsg('local-' + Date.now(), text, 'user', currentName || 'Anonymous', null); };
  });

  async function handleSend() {
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    localStorage.removeItem(LOCAL_DRAFT_KEY);
    sendBtn.disabled = true;
    try {
      if (sendMsgFn) await sendMsgFn(text);
      else renderMsg('local-' + Date.now(), text, 'user', currentName || 'Anonymous', null);
    } finally { sendBtn.disabled = false; }
  }

  sendBtn.addEventListener('click', handleSend);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') handleSend(); });
})();
</script>

<style>
  .chat-widget {
    position: fixed; bottom: 1.5rem; right: 1.5rem;
    z-index: 9999; display: flex; flex-direction: column; align-items: flex-end; gap: .75rem;
  }
  .chat-fab {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--cyan, #00d4ff); color: #02050a;
    border: none; border-radius: 999px; padding: .75rem 1.25rem;
    font-size: .875rem; font-weight: 600; font-family: inherit;
    cursor: pointer; box-shadow: 0 6px 24px rgba(0,212,255,.3);
    transition: background .15s, transform .15s;
  }
  .chat-fab:hover { background: #22e5ff; transform: scale(1.05); }
  .chat-fab:active { transform: scale(.97); }
  .chat-panel {
    width: 320px; border-radius: 18px; overflow: hidden;
    border: 1px solid rgba(255,255,255,.1); background: #0f172a;
    box-shadow: 0 24px 60px rgba(0,0,0,.5);
  }
  .chat-panel__header {
    display: flex; align-items: center; justify-content: space-between;
    background: #1e293b; border-bottom: 1px solid rgba(255,255,255,.07);
    padding: .75rem 1rem;
  }
  .chat-panel__title { display: flex; align-items: center; gap: .5rem; font-size: .875rem; font-weight: 600; color: #fff; }
  .chat-panel__badge { background: rgba(0,255,136,.15); color: #4ade80; border-radius: 999px; padding: .15rem .55rem; font-size: .65rem; font-weight: 600; }
  .chat-close { background: none; border: none; color: #94a3b8; font-size: 1.1rem; cursor: pointer; line-height: 1; padding: 0 2px; }
  .chat-close:hover { color: #fff; }
  .chat-messages { max-height: 280px; overflow-y: auto; padding: .75rem; display: flex; flex-direction: column; gap: .5rem; }
  .chat-input-row { display: flex; gap: .5rem; padding: .65rem; border-top: 1px solid rgba(255,255,255,.07); }
  .chat-input {
    flex: 1; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    border-radius: 8px; padding: .45rem .75rem; font-size: .82rem; color: #e2e8f0;
    outline: none; font-family: inherit;
  }
  .chat-input::placeholder { color: #475569; }
  .chat-input:focus { border-color: rgba(0,212,255,.4); }
  .chat-send-btn {
    flex-shrink: 0; width: 34px; height: 34px; background: var(--cyan, #00d4ff);
    border: none; border-radius: 8px; color: #02050a;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .15s;
  }
  .chat-send-btn:hover { background: #22e5ff; }
</style>
