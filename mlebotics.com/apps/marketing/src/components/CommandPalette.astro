---
// Command palette — opens on Ctrl+K or ⌘K, close on Escape or backdrop click
const pages = [
  { label: 'Home',          href: '/',              icon: '🏠', desc: 'Back to homepage' },
  { label: 'Projects',      href: '/projects',      icon: '🚀', desc: 'All MLEbotics projects' },
  { label: 'Blog',          href: '/blog',          icon: '✍️', desc: 'Articles and updates' },
  { label: 'About',         href: '/about',         icon: '👤', desc: 'About MLEbotics' },
  { label: 'Architecture',  href: '/architecture',  icon: '⚙️', desc: 'System architecture' },
  { label: 'Vision',        href: '/vision',        icon: '🔭', desc: 'Long-term vision' },
  { label: 'Mission',       href: '/mission',       icon: '🎯', desc: 'Our mission' },
  { label: 'Changelog',     href: '/changelog',     icon: '📋', desc: 'Release history' },
  { label: 'Contact',       href: '/contact',       icon: '✉️', desc: 'Get in touch' },
  { label: 'FAQ',           href: '/faq',           icon: '❓', desc: 'Frequently asked questions' },
  { label: 'Careers',       href: '/careers',       icon: '💼', desc: 'Join the team' },
  { label: 'Press',         href: '/press',         icon: '📰', desc: 'Press kit & media assets' },
  { label: 'Privacy',       href: '/privacy',       icon: '🔒', desc: 'Privacy policy' },
  { label: 'Terms',         href: '/terms',         icon: '📄', desc: 'Terms of service' },
  { label: 'Web Apps',      href: '/apps/web',      icon: '🌐', desc: 'Run in browser' },
  { label: 'Download Apps', href: '/apps/download', icon: '⬇️', desc: 'Install on device' },
  { label: 'Dashboard',     href: 'https://console.mlebotics.com', icon: '📊', desc: 'Open the console' },
  { label: 'Studio',        href: 'https://studio.mlebotics.com',  icon: '🎨', desc: 'Open studio' },
  { label: 'Docs',          href: 'https://docs.mlebotics.com',    icon: '📚', desc: 'Documentation' },
]
---

<!-- Command Palette overlay -->
<div id="cmd-overlay" class="cmd-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Command palette">
  <div class="cmd-box" id="cmd-box">
    <div class="cmd-input-wrap">
      <svg class="cmd-search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input
        type="search"
        id="cmd-input"
        class="cmd-input"
        placeholder="Search pages and actions…"
        autocomplete="off"
        spellcheck="false"
        aria-autocomplete="list"
        aria-controls="cmd-results"
      />
      <kbd class="cmd-esc-hint">ESC</kbd>
    </div>
    <ul id="cmd-results" class="cmd-results" role="listbox"></ul>
    <div class="cmd-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> select</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script define:vars={{ pages }}>
  const overlay  = document.getElementById('cmd-overlay')
  const box      = document.getElementById('cmd-box')
  const input    = document.getElementById('cmd-input')
  const results  = document.getElementById('cmd-results')
  let activeIdx  = -1

  function open() {
    overlay?.removeAttribute('aria-hidden')
    overlay?.classList.add('open')
    document.body.style.overflow = 'hidden'
    input?.focus()
    renderResults('')
  }
  function close() {
    overlay?.setAttribute('aria-hidden', 'true')
    overlay?.classList.remove('open')
    document.body.style.overflow = ''
    if (input) input.value = ''
    activeIdx = -1
  }

  function renderResults(q) {
    const query = q.toLowerCase().trim()
    const filtered = query
      ? pages.filter(p =>
          p.label.toLowerCase().includes(query) ||
          p.desc.toLowerCase().includes(query)
        )
      : pages
    if (!results) return
    results.innerHTML = filtered.map((p, i) => `
      <li
        class="cmd-item${i === activeIdx ? ' cmd-item--active' : ''}"
        role="option"
        aria-selected="${i === activeIdx}"
        data-href="${p.href}"
        data-idx="${i}"
      >
        <span class="cmd-item__icon" aria-hidden="true">${p.icon}</span>
        <span class="cmd-item__text">
          <span class="cmd-item__label">${p.label}</span>
          <span class="cmd-item__desc">${p.desc}</span>
        </span>
        <span class="cmd-item__arrow" aria-hidden="true">↗</span>
      </li>
    `).join('')
    // Rebind click
    results.querySelectorAll('.cmd-item').forEach(el => {
      el.addEventListener('click', () => {
        const href = el.getAttribute('data-href')
        if (href) { close(); window.location.href = href }
      })
    })
  }

  function navigate(dir) {
    const items = results?.querySelectorAll('.cmd-item')
    if (!items || items.length === 0) return
    items[activeIdx]?.classList.remove('cmd-item--active')
    items[activeIdx]?.setAttribute('aria-selected', 'false')
    activeIdx = (activeIdx + dir + items.length) % items.length
    const active = items[activeIdx]
    active?.classList.add('cmd-item--active')
    active?.setAttribute('aria-selected', 'true')
    active?.scrollIntoView({ block: 'nearest' })
  }

  input?.addEventListener('input', (e) => {
    activeIdx = -1
    renderResults((e.target).value)
  })

  document.addEventListener('keydown', (e) => {
    const isOpen = overlay?.classList.contains('open')
    // Open on Ctrl+K or ⌘K
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault()
      isOpen ? close() : open()
      return
    }
    if (!isOpen) return
    if (e.key === 'Escape') { close(); return }
    if (e.key === 'ArrowDown') { e.preventDefault(); navigate(1); return }
    if (e.key === 'ArrowUp')   { e.preventDefault(); navigate(-1); return }
    if (e.key === 'Enter') {
      e.preventDefault()
      const active = results?.querySelector('.cmd-item--active')
      const href = active?.getAttribute('data-href')
      if (href) { close(); window.location.href = href }
    }
  })

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) close()
  })

  // Expose for header search button
  window.__cmdOpen = open
</script>

<style>
  .cmd-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.65);
    backdrop-filter: blur(6px);
    z-index: 10000;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }
  .cmd-overlay.open { display: flex; }

  .cmd-box {
    background: #0d1117;
    border: 1px solid #2d3748;
    border-radius: 14px;
    width: min(640px, 92vw);
    max-height: 68vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,.7), 0 0 0 1px rgba(255,255,255,.04);
    animation: cmd-in .15s ease;
  }
  @keyframes cmd-in {
    from { opacity: 0; transform: scale(.97) translateY(-6px); }
    to   { opacity: 1; transform: none; }
  }

  .cmd-input-wrap {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .85rem 1.1rem;
    border-bottom: 1px solid #1e293b;
    flex-shrink: 0;
  }
  .cmd-search-icon { color: #64748b; flex-shrink: 0; }
  .cmd-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 1rem;
    color: #e2e8f0;
    font-family: inherit;
    caret-color: #00d4ff;
  }
  .cmd-input::placeholder { color: #475569; }
  .cmd-esc-hint {
    font-size: .65rem;
    background: #1e293b;
    color: #64748b;
    border: 1px solid #2d3748;
    border-radius: 4px;
    padding: .15rem .4rem;
    flex-shrink: 0;
  }

  .cmd-results {
    list-style: none;
    margin: 0;
    padding: .4rem;
    overflow-y: auto;
    flex: 1;
  }
  .cmd-item {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .65rem .85rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background .1s;
  }
  .cmd-item:hover,
  .cmd-item--active {
    background: rgba(0,212,255,.08);
  }
  .cmd-item__icon { font-size: 1rem; flex-shrink: 0; width: 1.4rem; text-align: center; }
  .cmd-item__text { flex: 1; display: flex; flex-direction: column; gap: .1rem; }
  .cmd-item__label { font-size: .875rem; font-weight: 500; color: #e2e8f0; }
  .cmd-item__desc  { font-size: .75rem; color: #64748b; }
  .cmd-item__arrow { font-size: .75rem; color: #334155; flex-shrink: 0; }
  .cmd-item--active .cmd-item__arrow { color: #00d4ff; }

  .cmd-footer {
    display: flex;
    gap: 1.5rem;
    padding: .6rem 1.1rem;
    border-top: 1px solid #1e293b;
    flex-shrink: 0;
  }
  .cmd-footer span { font-size: .7rem; color: #475569; display: flex; align-items: center; gap: .3rem; }
  .cmd-footer kbd {
    font-size: .65rem;
    background: #1e293b;
    border: 1px solid #2d3748;
    border-radius: 4px;
    padding: .1rem .35rem;
    color: #94a3b8;
  }
</style>
