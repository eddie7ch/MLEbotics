---
const links = [
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Architecture', href: '/architecture' },
  { label: 'About', href: '/about' },
  { label: 'Studio', href: 'https://studio.mlebotics.com' },
  { label: 'Docs', href: 'https://docs.mlebotics.com' },
]
const current = Astro.url.pathname
---

<div class="announce-bar" id="announce-bar" role="banner">
  <div class="announce-bar__inner">
    <span class="announce-bar__dot" aria-hidden="true"></span>
    <span class="announce-bar__text">
      <strong>Now live:</strong> RunCompanion v1.0 for Windows
      <a href="/apps/download" class="announce-bar__link">Get it now &rarr;</a>
    </span>
  </div>
  <button class="announce-bar__close" id="announce-close" aria-label="Dismiss announcement">&times;</button>
</div>

<header class="header" id="site-header">
  <div class="container header__inner">
    <a href="/" class="logo" aria-label="MLEbotics home">
      <svg class="logo__mark" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="22" height="22" rx="4" fill="#06080f"/>
        <path d="M4 6.5l4.5 4.5L4 15.5" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M10 6.5l4.5 4.5-4.5 4.5" stroke="#00d4ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M16 6.5l2.5 4.5-2.5 4.5" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>MLEbotics</span>
    </a>

    <nav class="nav" aria-label="Main navigation">
      <div class="nav__shell">
        {links.map((l) => (
          <a href={l.href} class={`nav__link${current.startsWith(l.href) ? ' active' : ''}`}>{l.label}</a>
        ))}

        <div class="dropdown" id="apps-dropdown">
          <button class="nav__link dropdown__trigger" aria-haspopup="true" aria-expanded="false" id="apps-btn">
            Apps <span class="dropdown__caret">▾</span>
          </button>
          <div class="dropdown__menu" role="menu" id="apps-menu">
            <a href="/apps/web" class="dropdown__item" role="menuitem">
              <span class="dropdown__icon" aria-hidden="true">🌐</span>
              <span>
                <strong>Web Apps</strong>
                <small>Run in your browser</small>
              </span>
            </a>
            <a href="/apps/download" class="dropdown__item" role="menuitem">
              <span class="dropdown__icon" aria-hidden="true">⬇️</span>
              <span>
                <strong>Download Apps</strong>
                <small>Install locally</small>
              </span>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <div class="header__actions">
      <button
        id="neural-toggle"
        class="header-neural-toggle"
        type="button"
        aria-pressed="true"
        aria-label="Turn neural background off"
        title="Toggle neural background"
      >
        <span class="neural-toggle__dot" aria-hidden="true"></span>
        <span class="neural-toggle__text">Neural: On</span>
      </button>

      <button
        id="motion-sound-toggle"
        class="header-sound-toggle"
        type="button"
        aria-pressed="false"
        aria-label="Enable interaction sound"
        title="Toggle interaction sound"
        data-no-neural
      >
        <svg class="header-sound-toggle__icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          <line class="header-sound-toggle__mute-line" x1="4" y1="20" x2="20" y2="4"></line>
        </svg>
      </button>

      <button class="header-search-btn" id="header-search-btn" aria-label="Search (Ctrl+K)" title="Search (Ctrl+K)">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="header-search-btn__label">Search</span>
        <kbd class="header-search-btn__kbd">⌘K</kbd>
      </button>

      <a href="/contact" class="btn-outline btn--sm header__cta">Start a project</a>
      <a href="https://console.mlebotics.com" class="btn-primary btn--sm header__cta header__cta--primary">Dashboard</a>
    </div>

    <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu__inner">
    <div class="mobile-menu__header">
      <a href="/" class="logo" aria-label="MLEbotics home">
        <svg class="logo__mark" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="22" height="22" rx="4" fill="#06080f"/>
          <path d="M4 6.5l4.5 4.5L4 15.5" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M10 6.5l4.5 4.5-4.5 4.5" stroke="#00d4ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 6.5l2.5 4.5-2.5 4.5" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>MLEbotics</span>
      </a>
      <button class="mobile-menu__close" id="mobile-close-btn" aria-label="Close menu">&times;</button>
    </div>

    <nav class="mobile-nav" aria-label="Mobile navigation">
      {links.map((l) => (
        <a href={l.href} class={`mobile-nav__link${current.startsWith(l.href) ? ' active' : ''}`}>{l.label}</a>
      ))}
      <a href="/apps/web" class="mobile-nav__link">Web Apps</a>
      <a href="/apps/download" class="mobile-nav__link">Download Apps</a>
      <a href="/faq" class="mobile-nav__link">FAQ</a>
      <a href="/changelog" class="mobile-nav__link">Changelog</a>
      <a href="/contact" class="mobile-nav__link">Contact</a>
    </nav>

    <div class="mobile-menu__actions">
      <a href="/contact" class="btn-outline mobile-menu__cta">Start a project</a>
      <a href="https://console.mlebotics.com" class="btn-primary mobile-menu__cta">Open Dashboard &rarr;</a>
    </div>
  </div>
</div>
<div class="mobile-menu__backdrop" id="mobile-backdrop"></div>

<script>
  function initHeaderUi() {
    const siteHeader = document.getElementById('site-header')
    const appsBtn = document.getElementById('apps-btn')
    const appsMenu = document.getElementById('apps-menu')
    const hamburger = document.getElementById('hamburger-btn')
    const mobileMenu = document.getElementById('mobile-menu')
    const mobileBackdrop = document.getElementById('mobile-backdrop')
    const mobileCloseBtn = document.getElementById('mobile-close-btn')
    const headerSearchBtn = document.getElementById('header-search-btn')
    const dropdownItems = document.querySelectorAll('.dropdown__item')
    const mobileNavLinks = document.querySelectorAll('.mobile-nav__link, .mobile-menu__cta')
    const announceBar = document.getElementById('announce-bar')
    const announceClose = document.getElementById('announce-close')

    // Clean up listeners when Astro swaps pages to avoid stale or duplicated handlers.
    const prevCleanup = window.__mleHeaderCleanup
    if (typeof prevCleanup === 'function') prevCleanup()
    const controller = new AbortController()
    const { signal } = controller
    window.__mleHeaderCleanup = () => controller.abort()

    let lastY = window.scrollY

    function onHeaderScroll() {
      if (!siteHeader) return
      const y = window.scrollY
      siteHeader.classList.toggle('header--scrolled', y > 16)

      const mobileOpen = mobileMenu?.classList.contains('open')
      if (!mobileOpen && y > lastY && y > 180) {
        siteHeader.classList.add('header--hidden')
      } else {
        siteHeader.classList.remove('header--hidden')
      }
      lastY = y
    }

    function closeAppsMenu() {
      appsMenu?.classList.remove('open')
      appsBtn?.setAttribute('aria-expanded', 'false')
    }

    function openMenu() {
      mobileMenu?.classList.add('open')
      mobileBackdrop?.classList.add('open')
      hamburger?.setAttribute('aria-expanded', 'true')
      hamburger?.classList.add('active')
      mobileMenu?.removeAttribute('aria-hidden')
      document.body.style.overflow = 'hidden'
      siteHeader?.classList.remove('header--hidden')
    }

    function closeMenu() {
      mobileMenu?.classList.remove('open')
      mobileBackdrop?.classList.remove('open')
      hamburger?.setAttribute('aria-expanded', 'false')
      hamburger?.classList.remove('active')
      mobileMenu?.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
    }

    function resetTransientState() {
      closeAppsMenu()
      closeMenu()
      document.body.style.overflow = ''
    }

    resetTransientState()
    onHeaderScroll()

    window.addEventListener('scroll', onHeaderScroll, { passive: true, signal })

    appsBtn?.addEventListener('click', (e) => {
      e.stopPropagation()
      const open = appsMenu?.classList.toggle('open')
      appsBtn.setAttribute('aria-expanded', String(open))
    }, { signal })

    document.addEventListener('click', () => closeAppsMenu(), { signal })
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeAppsMenu()
        closeMenu()
      }
    }, { signal })

    headerSearchBtn?.addEventListener('click', () => {
      if (typeof window.__cmdOpen === 'function') window.__cmdOpen()
    }, { signal })

    hamburger?.addEventListener('click', openMenu, { signal })
    mobileCloseBtn?.addEventListener('click', closeMenu, { signal })
    mobileBackdrop?.addEventListener('click', closeMenu, { signal })

    dropdownItems.forEach((item) => {
      item.addEventListener('click', () => {
        closeAppsMenu()
      }, { signal })
    })

    mobileNavLinks.forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu()
      }, { signal })
    })

    if (sessionStorage.getItem('announce-dismissed')) announceBar?.remove()
    announceClose?.addEventListener('click', () => {
      announceBar?.classList.add('announce-bar--hidden')
      setTimeout(() => announceBar?.remove(), 280)
      sessionStorage.setItem('announce-dismissed', '1')
    }, { signal })
  }

  initHeaderUi()
  document.addEventListener('astro:page-load', initHeaderUi)
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 220;
    backdrop-filter: blur(16px);
    background: linear-gradient(180deg, rgba(7,10,18,.92), rgba(7,10,18,.78));
    border-bottom: 1px solid var(--border);
    transition: transform .35s cubic-bezier(.22,1,.36,1), background .2s, border-color .2s;
  }
  .header--hidden {
    transform: translateY(calc(-100% - 4px));
  }
  .header--scrolled {
    background: linear-gradient(180deg, rgba(7,10,18,.98), rgba(7,10,18,.85));
    border-bottom-color: rgba(116, 209, 255, .2);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 66px;
  }

  .logo {
    font-family: var(--font-display);
    font-size: .9rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: .04em;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
  }
  .logo__mark { display: block; height: 22px; width: 22px; }

  .nav { display: flex; flex: 1; justify-content: center; }
  .nav__shell {
    display: inline-flex;
    align-items: center;
    gap: .1rem;
    border: 1px solid rgba(124, 145, 182, .22);
    border-radius: 999px;
    padding: .24rem;
    background: linear-gradient(170deg, rgba(15, 24, 39, .86), rgba(10, 16, 29, .75));
    box-shadow: 0 1px 0 rgba(255,255,255,.05) inset;
  }

  .nav__link {
    position: relative;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color .18s, background .18s;
    padding: .44rem .72rem;
    border-radius: 999px;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -6px;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #78daff, #9df2ca);
    transform: translateX(-50%);
    transition: width .18s ease;
    border-radius: 999px;
  }
  .nav__link:hover { color: #eaf2ff; background: rgba(255,255,255,.03); }
  .nav__link:hover::after { width: 44%; }
  .nav__link.active {
    color: #fff;
    background: rgba(0,212,255,.12);
    border-color: rgba(0,212,255,.25);
  }
  .nav__link.active::after { width: 56%; }

  .header__actions {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    flex-shrink: 0;
  }

  .header-sound-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    border: 1px solid rgba(125, 145, 182, .24);
    background: rgba(13, 17, 23, .8);
    color: #8ea7c8;
    cursor: pointer;
    transition: border-color .18s ease, color .18s ease, background .18s ease, transform .18s ease;
    backdrop-filter: blur(8px);
  }
  .header-sound-toggle:hover {
    border-color: rgba(116, 209, 255, .45);
    color: #d9e8ff;
    transform: translateY(-1px);
  }
  .header-sound-toggle.is-on {
    border-color: rgba(125, 243, 190, .42);
    color: #b5ffd7;
    background: rgba(17, 34, 31, .88);
  }
  .header-sound-toggle__icon {
    display: block;
  }
  .header-sound-toggle__mute-line {
    opacity: .9;
    transition: opacity .18s ease;
  }
  .header-sound-toggle.is-on .header-sound-toggle__mute-line {
    opacity: 0;
  }

  .header-neural-toggle {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    min-height: 36px;
    padding: .34rem .64rem;
    border-radius: 10px;
    border: 1px solid rgba(124, 145, 182, .16);
    background: rgba(255,255,255,.03);
    color: rgba(203, 213, 225, .72);
    font-family: inherit;
    font-size: .72rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color .15s, color .15s, background .15s, opacity .15s;
    flex-shrink: 0;
    white-space: nowrap;
    opacity: .78;
  }
  .header-neural-toggle:hover {
    border-color: rgba(124, 145, 182, .28);
    color: #fff;
    background: rgba(255,255,255,.05);
    opacity: 1;
  }
  .neural-toggle__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 10px rgba(74, 222, 128, .8);
    flex-shrink: 0;
  }
  html[data-neural-bg='off'] .neural-toggle__dot {
    background: #64748b;
    box-shadow: none;
  }

  .btn--sm { padding: .45rem .95rem; font-size: .76rem; }
  .header__cta { white-space: nowrap; }
  .header__cta--primary {
    box-shadow: 0 12px 22px rgba(9, 20, 36, .32);
  }

  .dropdown { position: relative; }
  .dropdown__trigger {
    background: none;
    cursor: pointer;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: .25rem;
  }
  .dropdown__caret { font-size: .65rem; transition: transform .2s; }
  .dropdown__menu {
    display: none;
    position: absolute;
    top: calc(100% + .75rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 230px;
    background: linear-gradient(170deg, rgba(18, 26, 42, .98), rgba(10, 16, 29, .98));
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: .5rem;
    z-index: 200;
    box-shadow: 0 16px 40px rgba(0,0,0,.5);
  }
  .dropdown__menu.open { display: flex; flex-direction: column; gap: .25rem; }
  [aria-expanded="true"] .dropdown__caret { transform: rotate(180deg); }

  .dropdown__item {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .65rem .85rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background .15s;
    color: #fff;
  }
  .dropdown__item:hover { background: rgba(255,255,255,.06); }
  .dropdown__icon { font-size: 1.1rem; flex-shrink: 0; }
  .dropdown__item strong { display: block; font-size: .85rem; font-weight: 600; }
  .dropdown__item small { display: block; font-size: .75rem; color: var(--muted); margin-top: .1rem; }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .5rem;
    margin-left: auto;
    border-radius: 6px;
    transition: background .15s;
  }
  .hamburger:hover { background: rgba(255,255,255,.06); }
  .hamburger__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform .25s, opacity .25s;
    transform-origin: center;
  }
  .hamburger.active .hamburger__bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active .hamburger__bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.active .hamburger__bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    width: min(340px, 85vw);
    height: 100dvh;
    background: #0a0d14;
    border-left: 1px solid var(--border);
    z-index: 400;
    transform: translateX(100%);
    transition: transform .3s cubic-bezier(.22,1,.36,1);
    display: flex;
    flex-direction: column;
  }
  .mobile-menu.open { transform: translateX(0); }

  .mobile-menu__inner {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.4rem 2rem;
    height: 100%;
    overflow-y: auto;
  }
  .mobile-menu__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .mobile-menu__close {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.6rem;
    cursor: pointer;
    padding: .25rem .5rem;
    line-height: 1;
    border-radius: 6px;
    transition: color .15s, background .15s;
  }
  .mobile-menu__close:hover { color: #fff; background: rgba(255,255,255,.06); }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: .25rem;
    flex: 1;
  }
  .mobile-nav__link {
    font-size: 1rem;
    color: var(--muted);
    text-decoration: none;
    padding: .75rem .5rem;
    border-radius: 8px;
    transition: color .15s, background .15s;
    border-bottom: 1px solid transparent;
  }
  .mobile-nav__link:hover { color: #fff; background: rgba(255,255,255,.04); }
  .mobile-nav__link.active { color: var(--cyan); }

  .mobile-menu__actions {
    display: grid;
    gap: .65rem;
    margin-top: 1.25rem;
  }
  .mobile-menu__cta {
    width: 100%;
    text-align: center;
    justify-content: center;
  }

  .mobile-menu__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.6);
    backdrop-filter: blur(4px);
    z-index: 300;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s;
  }
  .mobile-menu__backdrop.open { opacity: 1; pointer-events: all; }

  .announce-bar {
    background: linear-gradient(90deg, rgba(56,198,255,.13), rgba(244,209,143,.11));
    border-bottom: 1px solid rgba(116,209,255,.28);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: .55rem 1rem;
    gap: .75rem;
    font-size: .8rem;
    color: #cbd5e1;
    transition: opacity .3s, max-height .3s;
    overflow: hidden;
    max-height: 60px;
    position: relative;
  }
  .announce-bar--hidden { opacity: 0; max-height: 0; padding: 0; }
  .announce-bar__inner { display: flex; align-items: center; gap: .5rem; }
  .announce-bar__dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--green); }
    50% { opacity: .6; box-shadow: 0 0 12px var(--green); }
  }
  .announce-bar__text strong { color: var(--amber); }
  .announce-bar__link {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
    transition: color .15s;
    margin-left: .35rem;
  }
  .announce-bar__link:hover { color: var(--cyan); }
  .announce-bar__close {
    position: absolute;
    right: .75rem;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.1rem;
    cursor: pointer;
    line-height: 1;
    padding: .2rem .4rem;
    border-radius: 4px;
    transition: color .15s, background .15s;
  }
  .announce-bar__close:hover { color: #fff; background: rgba(255,255,255,.07); }

  .header-search-btn {
    display: flex;
    align-items: center;
    gap: .5rem;
    padding: .38rem .7rem;
    background: rgba(255,255,255,.05);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--muted);
    font-family: inherit;
    font-size: .76rem;
    cursor: pointer;
    transition: border-color .15s, color .15s, background .15s;
    flex-shrink: 0;
  }
  .header-search-btn:hover { border-color: rgba(0,212,255,.4); color: #fff; background: rgba(0,212,255,.05); }
  .header-search-btn__label { display: none; }
  .header-search-btn__kbd {
    font-size: .64rem;
    background: rgba(255,255,255,.07);
    border: 1px solid #2d3748;
    border-radius: 4px;
    padding: .1rem .3rem;
    color: #607088;
