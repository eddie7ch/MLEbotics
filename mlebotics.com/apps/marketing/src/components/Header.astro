---
const links = [
  { label: 'Projects',     href: '/projects' },
  { label: 'Blog',         href: '/blog' },
  { label: 'Architecture', href: '/architecture' },
  { label: 'About',        href: '/about' },
  { label: 'Studio',       href: 'https://studio.mlebotics.com' },
  { label: 'Docs',         href: 'https://docs.mlebotics.com' },
]
const current = Astro.url.pathname
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="logo" aria-label="MLEbotics home">
      <svg class="logo__mark" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="22" height="22" rx="4" fill="#06080f"/>
        <path d="M4 6.5l4.5 4.5L4 15.5" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M10 6.5l4.5 4.5-4.5 4.5" stroke="#00d4ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M16 6.5l2.5 4.5-2.5 4.5" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>MLEbotics</span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      {links.map(l => (
        <a href={l.href} class={`nav__link${current.startsWith(l.href) ? ' active' : ''}`}>{l.label}</a>
      ))}

      <!-- Apps dropdown -->
      <div class="dropdown" id="apps-dropdown">
        <button class="nav__link dropdown__trigger" aria-haspopup="true" aria-expanded="false" id="apps-btn">
          Apps <span class="dropdown__caret">▾</span>
        </button>
        <div class="dropdown__menu" role="menu" id="apps-menu">
          <a href="/apps/web" class="dropdown__item" role="menuitem">
            <span class="dropdown__icon">🌐</span>
            <span>
              <strong>Web Apps</strong>
              <small>Run in your browser</small>
            </span>
          </a>
          <a href="/apps/download" class="dropdown__item" role="menuitem">
            <span class="dropdown__icon">⬇️</span>
            <span>
              <strong>Downloadable Apps</strong>
              <small>Install on your device</small>
            </span>
          </a>
        </div>
      </div>
    </nav>

    <script>
      const btn = document.getElementById('apps-btn')
      const menu = document.getElementById('apps-menu')
      btn?.addEventListener('click', (e) => {
        e.stopPropagation()
        const open = menu?.classList.toggle('open')
        btn.setAttribute('aria-expanded', String(open))
      })
      document.addEventListener('click', () => {
        menu?.classList.remove('open')
        btn?.setAttribute('aria-expanded', 'false')
      })
    </script>
    <a href="https://console.mlebotics.com" class="btn-outline btn--sm">Dashboard &rarr;</a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(14px);
    background: rgba(6,8,15,.85);
    border-bottom: 1px solid var(--border);
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 64px;
  }
  .logo {
    font-family: 'Orbitron', monospace;
    font-size: .9rem;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    letter-spacing: .06em;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
  }
  .logo__mark {
    display: block;
    height: 22px;
    width: 22px;
  }
  .nav { display: flex; gap: 1.5rem; flex: 1; align-items: center; }
  .nav__link {
    font-size: .875rem;
    color: var(--muted);
    text-decoration: none;
    transition: color .15s;
    padding: .25rem 0;
    border-bottom: 2px solid transparent;
  }
  .nav__link:hover { color: #fff; }
  .nav__link.active { color: #fff; border-bottom-color: var(--cyan); }
  .btn--sm { padding: .45rem 1rem; font-size: .8rem; flex-shrink: 0; }

  /* Dropdown */
  .dropdown { position: relative; }
  .dropdown__trigger {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: .25rem;
  }
  .dropdown__caret { font-size: .65rem; transition: transform .2s; }
  .dropdown__menu {
    display: none;
    position: absolute;
    top: calc(100% + .75rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 220px;
    background: #0d1117;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: .5rem;
    z-index: 200;
    box-shadow: 0 16px 40px rgba(0,0,0,.5);
  }
  .dropdown__menu.open { display: flex; flex-direction: column; gap: .25rem; }
  .dropdown__menu.open ~ * .dropdown__caret,
  [aria-expanded="true"] .dropdown__caret { transform: rotate(180deg); }
  .dropdown__item {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .65rem .85rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background .15s;
    color: #fff;
  }
  .dropdown__item:hover { background: rgba(255,255,255,.06); }
  .dropdown__icon { font-size: 1.1rem; flex-shrink: 0; }
  .dropdown__item strong { display: block; font-size: .85rem; font-weight: 600; }
  .dropdown__item small { display: block; font-size: .75rem; color: var(--muted); margin-top: .1rem; }
</style>
