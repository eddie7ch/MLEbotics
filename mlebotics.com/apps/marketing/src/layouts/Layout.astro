---
import '../styles/global.css'
import ChatWidget from '@components/ChatWidget.astro'

interface Props {
  title: string
  description?: string
}
const { title, description = 'Building modular AI, automation, and robotics tools that remove friction and make life easier.' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — MLEbotics</title>
    <link rel="icon" type="image/png" href="/chevrons.png" />
    <link rel="apple-touch-icon" href="/chevrons.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@700;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <ChatWidget />
  </body>
</html>
