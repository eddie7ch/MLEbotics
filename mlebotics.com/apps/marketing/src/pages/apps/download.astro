---
import Layout from '@layouts/Layout.astro'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import '../../styles/global.css'

const apps = [
  {
    name: 'RunCompanion',
    icon: '🏃',
    tagline: 'AI running coach — Android, iOS & Windows',
    description: 'Cross-platform Flutter app. Plans training sessions, monitors pace and heart-rate zones, and syncs with robotics hardware via Bluetooth. Available on Android, iOS, and Windows.',
    platforms: ['Android', 'iOS', 'Windows'],
    downloadLinks: [
      { label: '⬇ Download .zip (Windows)', url: 'https://github.com/MLEbotics/MLEbotics/releases/download/runcompanion-windows-v1.0.0/runcompanion-windows.zip', primary: true },
      { label: 'Open Web App', url: 'https://runningcompanion.web.app', primary: false },
      { label: 'View Release', url: 'https://github.com/MLEbotics/MLEbotics/releases/tag/runcompanion-windows-v1.0.0', primary: false },
    ],
    stack: ['Flutter', 'Firebase', 'Dart'],
  },
  {
    name: 'MLEbotics Hub',
    icon: '🚀',
    tagline: 'Unified launcher for all MLEbotics tools',
    description: 'Single Windows EXE that launches and monitors all MLEbotics local agents and services. Built with PyInstaller — no Python install needed. Includes Hey Girl, Computer Use, and AutoFormFiller.',
    platforms: ['Windows'],
    downloadLinks: [
      { label: '⬇ Download .zip (Windows)', url: 'https://github.com/MLEbotics/MLEbotics/releases/download/hub-v1.0.0/mlebotics-hub.zip', primary: true },
      { label: 'View Release', url: 'https://github.com/MLEbotics/MLEbotics/releases/tag/hub-v1.0.0', primary: false },
    ],
    stack: ['Python', 'PyInstaller', 'Tkinter'],
  },
  {
    name: 'AutoFormFiller',
    icon: '📝',
    tagline: 'AI-powered Chrome extension for auto-filling forms',
    description: 'Chrome extension + Python backend. Reads any web form and fills it automatically using AI — ideal for job applications and event registrations. Load the extension from the downloaded zip.',
    platforms: ['Chrome Extension'],
    downloadLinks: [
      { label: '⬇ Download Extension .zip', url: 'https://github.com/MLEbotics/MLEbotics/releases/download/autoformfiller-v1.0.0/autoformfiller-extension.zip', primary: true },
      { label: 'View Release', url: 'https://github.com/MLEbotics/MLEbotics/releases/tag/autoformfiller-v1.0.0', primary: false },
    ],
    stack: ['Python', 'Flask', 'Chrome Extension', 'OpenAI'],
  },
  {
    name: 'Hey Girl',
    icon: '🎙️',
    tagline: 'Voice & text AI assistant for Windows',
    description: 'Wake-word activated AI assistant. Handles tasks, reads and summarizes assignments, solves quizzes, and answers questions with full conversation memory and Telegram integration. Requires Python and an OpenAI API key.',
    platforms: ['Windows'],
    downloadLinks: [
      { label: '⬇ Download Source .zip', url: 'https://github.com/MLEbotics/MLEbotics/releases/download/hey-girl-v1.0.0/hey-girl.zip', primary: true },
      { label: 'View Release', url: 'https://github.com/MLEbotics/MLEbotics/releases/tag/hey-girl-v1.0.0', primary: false },
    ],
    stack: ['Python', 'OpenAI', 'Tkinter', 'Telegram'],
  },
  {
    name: 'Computer Use Agent',
    icon: '🤖',
    tagline: 'AI desktop agent that sees and controls your screen',
    description: 'Anthropic Claude-powered agent. Takes screenshots of your desktop and performs tasks like a human — clicking, typing, navigating, and chaining actions automatically. Requires Python and an Anthropic API key.',
    platforms: ['Windows'],
    downloadLinks: [
      { label: '⬇ Download Source .zip', url: 'https://github.com/MLEbotics/MLEbotics/releases/download/computer-use-v1.0.0/computer-use.zip', primary: true },
      { label: 'View Release', url: 'https://github.com/MLEbotics/MLEbotics/releases/tag/computer-use-v1.0.0', primary: false },
    ],
    stack: ['Python', 'Anthropic', 'Claude'],
  },
  {
    name: 'Textual Data Processing',
    icon: '📄',
    tagline: 'Console app for analysing text statistics',
    description: 'Enter any paragraph and get instant stats: vowel count, word count, word frequency, and compound word handling. Self-contained Windows .exe — no .NET install required.',
    platforms: ['Windows'],
    downloadLinks: [
      { label: '⬇ Download .zip (Windows)', url: 'https://github.com/eddie7ch/OlderSchoolProjects/releases/download/textual-data-v1.0.0/textual-data-processing.zip', primary: true },
      { label: 'View Release', url: 'https://github.com/eddie7ch/OlderSchoolProjects/releases/tag/textual-data-v1.0.0', primary: false },
    ],
    stack: ['C#', '.NET', 'Console'],
  },
]

const platformColors: Record<string, string> = {
  'Android': '#3ddc84',
  'iOS': '#007aff',
  'Windows': '#0078d4',
  'Chrome Extension': '#fbbc04',
}
---

<Layout title="Downloadable Apps" description="Download MLEbotics apps for Windows, Android, iOS, and Chrome.">
  <Header />

  <main>
    <section class="section">
      <div class="container">
        <p class="tag">Downloadable Apps</p>
        <h1 class="section__h2">Install on your device</h1>
        <p class="page-sub">Native apps for Windows, Android, iOS, and Chrome.</p>

        <div class="apps-grid">
          {apps.map(app => (
            <div class="app-card">
              <div class="app-card__header">
                <span class="app-card__icon" aria-hidden="true">{app.icon}</span>
                <div class="platform-badges">
                  {app.platforms.map(p => (
                    <span class="platform-badge" style={`color: ${platformColors[p] ?? '#aaa'}; border-color: ${platformColors[p] ?? '#aaa'}33`}>{p}</span>
                  ))}
                </div>
              </div>
              <h2 class="app-card__name">{app.name}</h2>
              <p class="app-card__tagline">{app.tagline}</p>
              <p class="app-card__desc">{app.description}</p>
              <div class="app-card__stack">
                {app.stack.map(s => <span class="pill">{s}</span>)}
              </div>
              <div class="app-card__actions">
                {app.downloadLinks.map(link => (
                  <a href={link.url} class={link.primary ? 'btn-primary btn--sm' : 'btn-outline btn--sm'} target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-sub {
    color: var(--muted);
    font-size: 1rem;
    margin-bottom: 2.5rem;
  }
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .app-card {
    display: flex;
    flex-direction: column;
    gap: .75rem;
    padding: 1.75rem;
    background: var(--card-bg, rgba(255,255,255,.04));
    border: 1px solid var(--border);
    border-radius: 12px;
    color: inherit;
  }
  .app-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .5rem;
  }
  .app-card__icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    gap: .35rem;
    justify-content: flex-end;
  }
  .platform-badge {
    font-size: .65rem;
    font-weight: 700;
    padding: .2rem .5rem;
    border: 1px solid;
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .app-card__name {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
  }
  .app-card__tagline {
    font-size: .85rem;
    font-weight: 600;
    color: var(--accent, #6c63ff);
    margin: 0;
  }
  .app-card__desc {
    font-size: .875rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .app-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
  }
  .pill {
    font-size: .7rem;
    padding: .2rem .55rem;
    background: rgba(255,255,255,.07);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
  }
  .app-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: .25rem;
  }
</style>
