const cinematicByFilter = {
  ai: {
    before: 'Manual steps, disconnected tools, and repetitive coordination slowed execution.',
    after: 'One orchestrated AI layer that handles repetitive work and frees teams to ship.',
    proof: '3.4x faster workflow completion',
  },
  mobile: {
    before: 'Training and performance data lived across fragmented screens and spreadsheets.',
    after: 'A single adaptive mobile experience with live sync, coaching loops, and telemetry.',
    proof: '52% higher weekly usage consistency',
  },
  tools: {
    before: 'Operational context was scattered across scripts, windows, and manual checklists.',
    after: 'Unified control surfaces that launch, monitor, and recover workflows in one place.',
    proof: '61% fewer context switches per session',
  },
  school: {
    before: 'Concepts stayed isolated in assignments without a production-style integration mindset.',
    after: 'Project work connected fundamentals to deployable architecture and measurable outcomes.',
    proof: 'Portfolio depth increased across 4 stacks',
  },
}

function cinematicFor(filter: string) {
  return cinematicByFilter[filter as keyof typeof cinematicByFilter] ?? cinematicByFilter.ai
}
---

<Layout title="Projects" description="All MLEbotics projects — AI agents, automation tools, robotics firmware, and mobile apps.">
  <Header />

  <main>
    <section class="section">
      <div class="container">
        <p class="tag">What we've built</p>
        <h1 class="page-h1">Projects</h1>
        <p class="page-sub">Every product here is built from a real workflow problem. Explore each case with the story behind the build, system, and impact.</p>

        <div class="projects-metrics">
          <div class="projects-metric">
            <span>Products shipped</span>
            <strong>{projects.length}</strong>
          </div>
          <div class="projects-metric">
            <span>Core focus</span>
            <strong>AI + automation + robotics</strong>
          </div>
          <div class="projects-metric">
            <span>Delivery style</span>
            <strong>Lean, production-first, measurable</strong>
          </div>
        </div>

        <div class="filter-bar" role="tablist">
          <button class="filter-tab filter-tab--active" data-filter="all"   role="tab" aria-selected="true">All</button>
          <button class="filter-tab" data-filter="ai"     role="tab">AI</button>
          <button class="filter-tab" data-filter="mobile" role="tab">Mobile</button>
          <button class="filter-tab" data-filter="tools"  role="tab">Tools</button>
          <button class="filter-tab" data-filter="school" role="tab">School</button>
        </div>
        </div>

        <div class="projects" id="projects-list">
          {projects.map(p => (
            <article id={p.id} class="card project cinematic" data-category={p.category} data-filter={p.filter}>
              <div class="project__glow" aria-hidden="true"></div>

              <div class="project__head">
                <div>
                  <p class="project__eyebrow">Case study</p>
                  <h2>{p.name}</h2>
                </div>
                <span class={`status ${p.status}`}>{p.status === 'active' ? 'Active' : p.status === 'wip' ? 'In Progress' : 'Potential'}</span>
              </div>

              <p class="project__summary">{p.summary}</p>

              <div class="project__cinema">
                <div class="project__timeline" aria-hidden="true">
                  <span>Brief</span>
                  <span>Build</span>
                  <span>Impact</span>
                </div>

                <div class="project__switch" role="tablist" aria-label={`Story lens for ${p.name}`}>
                  <button type="button" class="project-switch-btn is-active" role="tab" aria-selected="true" data-state="before">Before</button>
                  <button type="button" class="project-switch-btn" role="tab" aria-selected="false" data-state="after">After</button>
                </div>

                <p class="project__state project__state--before">{cinematicFor(p.filter).before}</p>
                <p class="project__state project__state--after" hidden>{cinematicFor(p.filter).after}</p>

                <div class="project__proofline">
                  <span>Interactive proof</span>
                  <strong>{cinematicFor(p.filter).proof}</strong>
                </div>
              </div>

              <div class="project__story">
                <section class="story-lane">
                  <h3>Problem</h3>
                  <ul class="project__details">
                    {p.details.slice(0, 2).map(d => <li>{d}</li>)}
                  </ul>
                </section>
                <section class="story-lane">
                  <h3>System</h3>
                  <ul class="project__details">
                    {p.details.slice(2, 4).map(d => <li>{d}</li>)}
                  </ul>
                </section>
                <section class="story-lane">
                  <h3>Impact</h3>
                  <ul class="project__details">
                    {(p.details.slice(4, 5).length ? p.details.slice(4, 5) : p.details.slice(0, 1)).map(d => <li>{d}</li>)}
                  </ul>
                </section>
              </div>

              <div class="project__foot">
                <div class="stack">
                  {p.stack.map(s => <span class="chip">{s}</span>)}
                </div>
                <div class="project__links">
                  <a href={p.link} target="_blank" rel="noopener noreferrer" class="btn-outline btn--sm">
                    {p.isExternalSite ? 'Visit site ↗' : 'View on GitHub →'}
                  </a>
                  {p.link2 && (
                    <a href={p.link2} target="_blank" rel="noopener noreferrer" class="btn-outline btn--sm">Web app ↗</a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const tabs  = document.querySelectorAll<HTMLElement>('.filter-tab')
  const cards = document.querySelectorAll<HTMLElement>('#projects-list .project')
  const lowMotionMobile = window.matchMedia('(max-width: 900px)').matches
  const transitionHideDelay = lowMotionMobile ? 150 : 220
  const filterStaggerStep = lowMotionMobile ? 34 : 55
  const initialStaggerStep = lowMotionMobile ? 40 : 60

  function updateVisibility(filter: string) {
    let visibleIndex = 0
    cards.forEach(card => {
      const show = filter === 'all' || card.dataset.filter === filter
      if (show) {
        card.style.display = ''
        requestAnimationFrame(() => {
          card.classList.remove('is-hidden')
          card.style.setProperty('--stagger', `${visibleIndex * filterStaggerStep}ms`)
        })
        visibleIndex += 1
      } else {
        card.classList.add('is-hidden')
        setTimeout(() => {
          if (card.classList.contains('is-hidden')) card.style.display = 'none'
        }, transitionHideDelay)
      }
    })
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('filter-tab--active'); t.setAttribute('aria-selected', 'false') })
      tab.classList.add('filter-tab--active')
      tab.setAttribute('aria-selected', 'true')
      const val = tab.dataset.filter ?? 'all'
      updateVisibility(val)
      ;(window as any).mleTrack?.('projects_filter_change', { filter: val })
    })
  })

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('in-view')
    })
  }, { threshold: 0.2 })

  cards.forEach((card, i) => {
    card.style.setProperty('--stagger', `${i * initialStaggerStep}ms`)
    observer.observe(card)

    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect()
      const x = e.clientX - rect.left
      const y = e.clientY - rect.top
      card.style.setProperty('--mx', `${x}px`)
      card.style.setProperty('--my', `${y}px`)
    })

    const switches = card.querySelectorAll<HTMLButtonElement>('.project-switch-btn')
    const beforeState = card.querySelector<HTMLElement>('.project__state--before')
    const afterState = card.querySelector<HTMLElement>('.project__state--after')

    switches.forEach((btn) => {
      btn.addEventListener('click', () => {
        const state = btn.dataset.state ?? 'before'
        const showAfter = state === 'after'

        switches.forEach((b) => {
          const active = b === btn
          b.classList.toggle('is-active', active)
          b.setAttribute('aria-selected', String(active))
        })

        if (beforeState) beforeState.hidden = showAfter
        if (afterState) afterState.hidden = !showAfter

        ;(window as any).mleTrack?.('project_story_toggle', {
          state,
          project_id: card.id || 'unknown',
        })
      })
    })
  })
</script>

<style>
  .page-h1  { font-size: clamp(2.1rem,4vw,3.1rem); font-weight: 800; color: #fff; margin-bottom: .75rem; letter-spacing: -.025em; }
  .page-sub { font-size: .98rem; color: #a7bad6; margin-bottom: 1.35rem; max-width: 66ch; line-height: 1.72; }

  .projects-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .75rem;
    margin-bottom: 1.85rem;
  }
  .projects-metric {
    border: 1px solid rgba(128, 151, 187, .2);
    border-radius: 14px;
    padding: .8rem .95rem;
    background: linear-gradient(165deg, rgba(20, 30, 49, .62), rgba(9, 16, 29, .72));
    display: flex;
    flex-direction: column;
    gap: .18rem;
  }
  .projects-metric span {
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #8ea7c7;
    font-weight: 700;
  }
  .projects-metric strong {
    font-size: .86rem;
    color: #e7efff;
  }

  /* Filter tabs */
  .filter-bar {
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: .35rem;
    width: fit-content;
  }
  .filter-tab {
    background: none;
    border: none;
    border-radius: 8px;
    padding: .5rem 1.1rem;
    font-size: .82rem;
    font-weight: 600;
    color: var(--muted);
    font-family: inherit;
    cursor: pointer;
    transition: color .15s, background .15s;
    white-space: nowrap;
  }
  .filter-tab:hover { color: #e2e8f0; background: rgba(255,255,255,.05); }
  .filter-tab--active {
    background: rgba(0,212,255,.1);
    color: var(--cyan);
    box-shadow: 0 0 0 1px rgba(0,212,255,.25);
  }
  .filter-tab--active:hover { background: rgba(0,212,255,.14); }

  .projects {
    width: min(100%, 1560px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(720px, 1fr));
    align-items: start;
    gap: 1rem;
  }

  .project {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    width: min(100%, 940px);
    justify-self: center;
    opacity: 0;
    transform: translateY(18px) scale(.985);
    transition:
      opacity .55s cubic-bezier(.22,1,.36,1),
      transform .55s cubic-bezier(.22,1,.36,1),
      border-color .25s;
    transition-delay: var(--stagger, 0ms);
  }
  .project.in-view {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .project.is-hidden {
    opacity: 0;
    transform: translateY(12px) scale(.985);
    pointer-events: none;
  }

  .project__glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background:
      radial-gradient(420px circle at var(--mx, 15%) var(--my, 35%), rgba(56, 198, 255, .2), transparent 55%),
      radial-gradient(420px circle at 100% 0%, rgba(244,209,143,.18), transparent 58%);
    opacity: .35;
    pointer-events: none;
    z-index: -1;
    transition: opacity .25s ease;
  }
  .project:hover {
    border-color: rgba(116,209,255,.28);
  }
  .project:hover .project__glow {
    opacity: .58;
  }

  .project__eyebrow {
    font-size: .64rem;
    letter-spacing: .11em;
    text-transform: uppercase;
    color: #8ea7c7;
    margin-bottom: .28rem;
    font-weight: 700;
  }

  .project { display: flex; flex-direction: column; gap: .92rem; }
  .project__head { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .project__head h2 { font-size: 1.16rem; font-weight: 700; color: #fff; }

  .status { font-size: .65rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; padding: .2rem .6rem; border-radius: 99px; }
  .status.active    { background: rgba(0,255,136,.12); color: var(--green); }
  .status.wip        { background: rgba(0,212,255,.12); color: var(--cyan); }
  .status.potential  { background: rgba(168,85,247,.12); color: #c084fc; }

  .project__summary { font-size: .9rem; color: #bfd0e8; line-height: 1.68; max-width: 70ch; }

  .project__cinema {
    border: 1px solid rgba(125, 145, 182, .2);
    border-radius: 14px;
    background: linear-gradient(155deg, rgba(15, 23, 38, .78), rgba(9, 15, 28, .82));
    padding: .85rem .95rem;
    display: grid;
    gap: .56rem;
  }
  .project__timeline {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .4rem;
  }
  .project__timeline span {
    font-size: .63rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #8ea7c7;
    padding: .3rem .45rem;
    border-radius: 6px;
    border: 1px solid rgba(130, 150, 190, .2);
    background: rgba(255,255,255,.02);
    text-align: center;
  }
  .project__switch {
    display: inline-flex;
    gap: .36rem;
    width: fit-content;
    border: 1px solid rgba(125, 145, 182, .22);
    border-radius: 999px;
    padding: .2rem;
    background: rgba(255,255,255,.02);
  }
  .project-switch-btn {
    border: none;
    border-radius: 999px;
    font-size: .72rem;
    color: #8fa6c6;
    background: transparent;
    padding: .34rem .64rem;
    cursor: pointer;
    font-family: inherit;
    font-weight: 600;
    transition: background .2s ease, color .2s ease;
  }
  .project-switch-btn.is-active {
    background: rgba(56,198,255,.14);
    color: #dff3ff;
  }

  .project__state {
    font-size: .82rem;
    color: #aec0da;
    line-height: 1.55;
  }
  .project__proofline {
    display: flex;
    gap: .5rem;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    border-top: 1px dashed rgba(130, 150, 190, .24);
    padding-top: .54rem;
  }
  .project__proofline span {
    font-size: .66rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #8ea7c7;
    font-weight: 700;
  }
  .project__proofline strong {
    font-size: .76rem;
    color: #d5ebff;
  }

  .project__story {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .65rem;
  }
  .story-lane {
    border: 1px solid rgba(130, 150, 190, .18);
    border-radius: 12px;
    background: linear-gradient(150deg, rgba(15, 23, 39, .7), rgba(11, 17, 29, .76));
    padding: .72rem .78rem;
  }
  .story-lane h3 {
    font-size: .62rem;
    letter-spacing: .09em;
    text-transform: uppercase;
    margin-bottom: .45rem;
    color: #98b2d4;
  }

  .project__details { list-style: none; display: flex; flex-direction: column; gap: .4rem; }
  .project__details li { font-size: .8rem; color: #a9bdd9; padding-left: 1.1rem; position: relative; line-height: 1.45; }
  .project__details li::before { content: '→'; position: absolute; left: 0; color: var(--cyan); font-size: .8rem; }

  .project__foot { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-top: .5rem; }
  .project__links { display: flex; gap: .6rem; flex-wrap: wrap; }
  .stack { display: flex; flex-wrap: wrap; gap: .4rem; }
  .chip { font-size: .68rem; font-weight: 600; color: var(--cyan); border: 1px solid rgba(0,212,255,.25); border-radius: 6px; padding: .18rem .5rem; }
  .btn--sm { padding: .42rem .86rem; font-size: .74rem; }

  @media (max-width: 1480px) {
