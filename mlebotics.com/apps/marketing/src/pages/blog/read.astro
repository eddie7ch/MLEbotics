---
import Layout from '@layouts/Layout.astro'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import PostReader from '@components/PostReader'
---

<Layout
  title="Blog Post"
  description="Read the latest posts from MLEbotics."
>
  <Header />

  <main id="main-content">
    <!-- Reading progress bar (post-specific, separate from global scroll progress) -->
    <div id="post-reading-bar" aria-hidden="true"></div>

    <section class="section">
      <div class="container post-container">
        <PostReader client:load />

        <!-- Social share bar (rendered after post content loads) -->
        <div class="post-share-bar" id="post-share-bar">
          <span class="post-share-label">Share this post</span>
          <div class="post-share-btns">
            <button id="share-tw" class="share-btn share-btn--tw" title="Share on X / Twitter">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X / Twitter
            </button>
            <button id="share-li" class="share-btn share-btn--li" title="Share on LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </button>
            <button id="share-copy" class="share-btn share-btn--copy" title="Copy link">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy link
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Reading progress bar
  const bar = document.getElementById('post-reading-bar')
  if (bar) {
    window.addEventListener('scroll', () => {
      const body = document.body
      const docEl = document.documentElement
      const scrollTop = window.scrollY
      const total = Math.max(body.scrollHeight, docEl.scrollHeight) - window.innerHeight
      bar.style.width = total > 0 ? (scrollTop / total * 100) + '%' : '0%'
    }, { passive: true })
  }

  // Social share
  function getTitle() {
    return document.querySelector('.post-title')?.textContent?.trim() || document.title
  }
  document.getElementById('share-tw')?.addEventListener('click', () => {
    const url = encodeURIComponent(location.href)
    const text = encodeURIComponent(getTitle() + ' via @MLEbotics')
    window.open(`https://twitter.com/intent/tweet?url=${url}&text=${text}`, '_blank', 'noopener,noreferrer,width=600,height=400')
  })
  document.getElementById('share-li')?.addEventListener('click', () => {
    const url = encodeURIComponent(location.href)
    window.open(`https://www.linkedin.com/shareArticle?mini=true&url=${url}`, '_blank', 'noopener,noreferrer,width=600,height=600')
  })
  document.getElementById('share-copy')?.addEventListener('click', () => {
    navigator.clipboard.writeText(location.href).then(() => {
      const btn = document.getElementById('share-copy')
      if (btn) {
        btn.textContent = '✓ Copied!'
        setTimeout(() => btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy link`, 2000)
      }
      if (typeof window.showToast === 'function') window.showToast('Link copied to clipboard!', 'success')
    })
  })

  // Copy-code buttons on <pre> blocks
  function addCopyButtons() {
    document.querySelectorAll('.post-body pre').forEach((pre) => {
      if (pre.querySelector('.copy-code-btn')) return
      const btn = document.createElement('button')
      btn.className = 'copy-code-btn'
      btn.setAttribute('aria-label', 'Copy code')
      btn.textContent = 'Copy'
      btn.addEventListener('click', () => {
        const code = pre.querySelector('code')?.textContent || ''
        navigator.clipboard.writeText(code).then(() => {
          btn.textContent = 'Copied!'
          setTimeout(() => { btn.textContent = 'Copy' }, 2000)
        })
      })
      ;(pre as HTMLElement).style.position = 'relative'
      pre.appendChild(btn)
    })
  }
  // Run after PostReader hydrates
  setTimeout(addCopyButtons, 800)
  document.addEventListener('astro:page-load', addCopyButtons)
</script>

<style>
  /* Post reading progress bar */
  #post-reading-bar {
    position: fixed;
    top: 3px; /* below global scroll progress */
    left: 0;
    height: 2px;
    width: 0;
    background: var(--green);
    z-index: 9998;
    transition: width .1s linear;
    pointer-events: none;
  }

  .post-container { max-width: 740px; }

  /* Social share bar */
  .post-share-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.5rem 0;
    margin-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .post-share-label { font-size: .8rem; font-weight: 600; color: var(--muted); flex-shrink: 0; }
  .post-share-btns  { display: flex; gap: .5rem; flex-wrap: wrap; }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .4rem .85rem;
    font-size: .78rem;
    font-weight: 600;
    border-radius: 8px;
    border: 1px solid var(--border);
    cursor: pointer;
    font-family: inherit;
    background: rgba(255,255,255,.04);
    color: var(--muted);
    transition: border-color .15s, color .15s, background .15s;
  }
  .share-btn:hover { border-color: rgba(0,212,255,.4); color: #fff; background: rgba(0,212,255,.07); }

  /* Copy-code button */
  :global(.copy-code-btn) {
    position: absolute !important;
    top: .65rem;
    right: .65rem;
    padding: .25rem .6rem;
    font-size: .7rem;
    font-weight: 600;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 5px;
    color: #94a3b8;
    cursor: pointer;
    font-family: inherit;
    transition: background .15s, color .15s;
    z-index: 2;
  }
  :global(.copy-code-btn:hover) { background: rgba(0,212,255,.15); color: var(--cyan); }

  /* Rendered markdown body styles */
  :global(.post-body h1),
  :global(.post-body h2),
  :global(.post-body h3) {
    color: #fff;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: .75rem;
    line-height: 1.3;
  }
  :global(.post-body h1) { font-size: 1.6rem; }
  :global(.post-body h2) { font-size: 1.3rem; }
  :global(.post-body h3) { font-size: 1.1rem; }
  :global(.post-body p) {
    margin-bottom: 1.2rem;
    color: #cbd5e1;
    line-height: 1.85;
  }
  :global(.post-body strong) { color: #fff; font-weight: 600; }
  :global(.post-body em) { color: #e2e8f0; font-style: italic; }
  :global(.post-body code) {
    background: rgba(0,212,255,.08);
    border: 1px solid rgba(0,212,255,.15);
    border-radius: 4px;
    padding: .15rem .4rem;
    font-size: .85em;
    color: var(--cyan);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  :global(.post-body pre) {
    background: rgba(0,0,0,.4);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  :global(.post-body pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #e2e8f0;
    font-size: .875rem;
  }
  :global(.post-body hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
</style>

