---
import Layout from '@layouts/Layout.astro'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <Header />
  <main id="main-content" class="notfound">
    <div class="container notfound__inner">
      <div class="notfound__code" aria-hidden="true">404</div>
      <h1 class="notfound__title">Page not found</h1>
      <p class="notfound__sub">The page you're looking for doesn't exist or has been moved.</p>
      <div class="notfound__actions">
        <a href="/" class="btn-primary">Go home</a>
        <a href="/projects" class="btn-outline">See projects</a>
        <a href="/blog" class="btn-outline">Read the blog</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .notfound {
    min-height: calc(100dvh - 64px - 300px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 0;
  }
  .notfound__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .notfound__code {
    font-family: 'Orbitron', monospace;
    font-size: clamp(5rem, 18vw, 10rem);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, #00d4ff, #00ff88);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: .35;
    user-select: none;
  }
  .notfound__title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: #fff;
  }
  .notfound__sub {
    font-size: 1rem;
    color: var(--muted);
    max-width: 380px;
    line-height: 1.7;
  }
  .notfound__actions {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
  }
</style>
