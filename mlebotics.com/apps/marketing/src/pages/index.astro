---
import Layout from '@layouts/Layout.astro'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import '../styles/global.css'
---

<Layout title="MLEbotics" description="Building modular AI, automation, and robotics tools that remove friction and make life easier.">
  <Header />

  <main id="main-content">
    <!-- ── Hero ────────────────────────────────────────────────────── -->
    <section class="hero section">
      <div class="container hero__inner">
        <div class="hero__badge">
          <span class="dot"></span>
          AI · Automation · Humanoid Robotics
        </div>
        <h1 class="hero__h1">
          <span id="typewriter" aria-live="polite"></span><br />
          <span class="gradient-text">Build smarter tools.</span>
        </h1>
        <p class="hero__sub" id="hero-sub">
          MLEbotics designs premium AI, automation, and robotics systems that feel
          fast, dependable, and deeply intentional from day one.
        </p>
        <div class="hero__cta">
          <a href="/projects" class="btn-primary" id="hero-cta-primary" data-cta="hero_primary_projects" data-magnetic>See our projects</a>
          <a href="/about" class="btn-outline" id="hero-cta-outline" data-cta="hero_secondary_about" data-magnetic>About us</a>
        </div>
        <div class="hero-proof reveal reveal-delay-2" aria-label="Delivery highlights">
          <div class="hero-proof__item">
            <span class="hero-proof__value">7-day</span>
            <span class="hero-proof__label">prototype sprint</span>
          </div>
          <div class="hero-proof__item">
            <span class="hero-proof__value">Modular</span>
            <span class="hero-proof__label">architecture by default</span>
          </div>
          <div class="hero-proof__item">
            <span class="hero-proof__value">Production</span>
            <span class="hero-proof__label">telemetry and analytics</span>
          </div>
        </div>
        <!-- Trust bar -->
        <div class="hero__trust" aria-label="Built with">
          <span class="hero__trust-label">Powered by</span>
          <div class="hero__trust-logos" aria-hidden="true">
            <div class="hero__trust-track">
              <span>Flutter</span>
              <span class="trust-sep">·</span>
              <span>Firebase</span>
              <span class="trust-sep">·</span>
              <span>OpenAI</span>
              <span class="trust-sep">·</span>
              <span>Anthropic</span>
              <span class="trust-sep">·</span>
              <span>Vercel</span>
              <span class="trust-sep">·</span>
              <span>Python</span>
              <span class="trust-sep">·</span>
              <span>Astro</span>
            </div>
            <div class="hero__trust-track" aria-hidden="true">
              <span>Flutter</span>
              <span class="trust-sep">·</span>
              <span>Firebase</span>
              <span class="trust-sep">·</span>
              <span>OpenAI</span>
              <span class="trust-sep">·</span>
              <span>Anthropic</span>
              <span class="trust-sep">·</span>
              <span>Vercel</span>
              <span class="trust-sep">·</span>
              <span>Python</span>
              <span class="trust-sep">·</span>
              <span>Astro</span>
            </div>
          </div>
        </div>
      </div>
      <!-- Aurora background -->
      <div class="aurora" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
        <div class="aurora__blob aurora__blob--3"></div>
        <div class="aurora__grid"></div>
      </div>
    </section>

    <!-- ── Stats ────────────────────────────────────────────────────── -->
    <section class="section stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item reveal reveal-delay-1">
            <div class="stat-numwrap"><span class="stat-num" data-target="6">0</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">Projects shipped</p>
          </div>
          <div class="stat-item reveal reveal-delay-2">
            <div class="stat-numwrap"><span class="stat-num" data-target="5">0</span></div>
            <p class="stat-label">Platforms supported</p>
          </div>
          <div class="stat-item reveal reveal-delay-3">
            <div class="stat-numwrap"><span class="stat-num" data-target="3">0</span><span class="stat-suffix">+</span></div>
            <p class="stat-label">AI APIs integrated</p>
          </div>
          <div class="stat-item reveal reveal-delay-4">
            <div class="stat-numwrap"><span class="stat-num" data-target="100">0</span><span class="stat-suffix">%</span></div>
            <p class="stat-label">Open source</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Interactive control room ───────────────────────────────── -->
    <section class="section command-section">
      <div class="container reveal">
        <p class="tag">Interactive experience</p>
        <h2 class="section__h2">One operating layer for build, automate, and scale</h2>

        <div class="command-shell" id="command-shell" data-mode="build">
          <div class="command-shell__top">
            <p class="command-shell__label">MLEbotics Control Room</p>
            <div class="command-mode-switch" role="tablist" aria-label="Preview modes">
              <button class="command-mode-btn active" type="button" data-mode="build" aria-pressed="true">Build</button>
              <button class="command-mode-btn" type="button" data-mode="operate" aria-pressed="false">Operate</button>
              <button class="command-mode-btn" type="button" data-mode="scale" aria-pressed="false">Scale</button>
            </div>
          </div>

          <div class="command-grid">
            <article class="command-panel command-panel--left">
              <p class="command-kicker" id="command-kicker">Build mode</p>
              <h3 class="command-title" id="command-title">Design, prototype, and ship with product-grade speed.</h3>
              <p class="command-copy" id="command-copy">From architecture maps to deploy-ready modules, every phase stays connected so your team can move from concept to production without handoff friction.</p>

              <div class="command-metrics" aria-label="Performance metrics">
                <div class="command-metric">
                  <span class="command-metric__label">Time to first demo</span>
                  <strong class="command-metric__value" id="metric-a">7 days</strong>
                </div>
                <div class="command-metric">
                  <span class="command-metric__label">Automation reliability</span>
                  <strong class="command-metric__value" id="metric-b">99.4%</strong>
                </div>
                <div class="command-metric">
                  <span class="command-metric__label">Deploy confidence</span>
                  <strong class="command-metric__value" id="metric-c">Production-ready</strong>
                </div>
              </div>
            </article>

            <aside class="command-panel command-panel--right" aria-label="Operational signals">
              <div class="signal-head">
                <span class="signal-head__dot" aria-hidden="true"></span>
                <span>Live system signals</span>
              </div>

              <div class="signal-stream">
                <div class="signal-stream__row"><span>Automation queue</span><span id="signal-queue">26 active jobs</span></div>
                <div class="signal-stream__row"><span>AI response latency</span><span id="signal-latency">312ms</span></div>
                <div class="signal-stream__row"><span>Cross-platform sync</span><span id="signal-sync">Stable</span></div>
              </div>

              <div class="signal-bars" aria-hidden="true">
                <div class="signal-bars__item"><span>Agents</span><i style="--w: 78%"></i></div>
                <div class="signal-bars__item"><span>Automation</span><i style="--w: 92%"></i></div>
                <div class="signal-bars__item"><span>Robotics</span><i style="--w: 64%"></i></div>
              </div>

              <p class="signal-note">Switch modes to preview how the platform adapts from launch to growth.</p>
            </aside>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Capabilities ─────────────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <p class="tag">What we build</p>
        <h2 class="section__h2">Modular tools for every layer</h2>
        <div class="grid3">
          <div class="card cap-card tilt-card reveal reveal-delay-1">
            <div class="cap-icon" aria-hidden="true">
              <!-- Brain / AI -->
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>
            </div>
            <h3>AI Agents</h3>
            <p>Context-aware agents that read, reason, and act — from scheduling to document processing to full desktop automation.</p>
          </div>
          <div class="card cap-card tilt-card reveal reveal-delay-2">
            <div class="cap-icon" aria-hidden="true">
              <!-- Settings / Automation -->
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M12 2v2"/><path d="M12 22v-2"/><path d="m17 20.66-1-1.73"/><path d="M11 10.27 7 3.34"/><path d="m20.66 17-1.73-1"/><path d="m3.34 7 1.73 1"/><path d="M14 12h8"/><path d="M2 12h2"/><path d="m20.66 7-1.73 1"/><path d="m3.34 17 1.73-1"/><path d="m17 3.34-1 1.73"/><path d="m11 13.73-4 6.93"/></svg>
            </div>
            <h3>Automation</h3>
            <p>End-to-end workflow automation: form filling, data extraction, notification routing, and API orchestration.</p>
          </div>
          <div class="card cap-card tilt-card reveal reveal-delay-3">
            <div class="cap-icon" aria-hidden="true">
              <!-- CPU / Robotics -->
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
            </div>
            <h3>Robotics Firmware</h3>
            <p>Lightweight firmware and companion apps for physical robots — bridging embedded hardware to cloud intelligence.</p>
          </div>
          <div class="card cap-card tilt-card reveal reveal-delay-1">
            <div class="cap-icon" aria-hidden="true">
              <!-- Smartphone -->
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/></svg>
            </div>
            <h3>Mobile Apps</h3>
            <p>Cross-platform Flutter applications — from running trackers to AI-powered coaching dashboards.</p>
          </div>
          <div class="card cap-card tilt-card reveal reveal-delay-2">
            <div class="cap-icon" aria-hidden="true">
              <!-- Bar chart -->
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/><line x1="2" x2="22" y1="20" y2="20"/></svg>
            </div>
            <h3>Dashboards</h3>
            <p>Real-time monitoring dashboards that surface the data you care about, without the noise you don't.</p>
          </div>
          <div class="card cap-card tilt-card reveal reveal-delay-3">
            <div class="cap-icon" aria-hidden="true">
              <!-- Link / Integrations -->
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            <h3>Integrations</h3>
            <p>Plug-and-play connectors for Telegram, Firebase, OpenAI, Anthropic, and your existing stack.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Build process ────────────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <p class="tag">How we ship</p>
        <h2 class="section__h2">Designed like a product studio, engineered like a lab</h2>
        <div class="process-grid">
          <article class="process-card card reveal reveal-delay-1">
            <span class="process-step">01</span>
            <h3>Architecture first</h3>
            <p>We map data flow, automation boundaries, and integration contracts before writing production code.</p>
          </article>
          <article class="process-card card reveal reveal-delay-2">
            <span class="process-step">02</span>
            <h3>Fast functional prototypes</h3>
            <p>Clickable and testable prototypes land early so every decision gets validated with real feedback.</p>
          </article>
          <article class="process-card card reveal reveal-delay-3">
            <span class="process-step">03</span>
            <h3>Reliable production delivery</h3>
            <p>We ship with observability, analytics, and maintainable modules so growth does not create fragility.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ── Feature comparison ─────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <p class="tag">Why MLEbotics</p>
        <h2 class="section__h2">Ship faster than building from scratch</h2>
        <div class="compare-wrap">
          <table class="compare-table" role="table" aria-label="MLEbotics vs building from scratch">
            <thead>
              <tr>
                <th scope="col">Feature</th>
                <th scope="col" class="compare-col--mle">
                  <div class="compare-logo">
                    <svg class="logo__mark" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="18" height="18">
                      <rect width="22" height="22" rx="4" fill="#06080f"/>
                      <path d="M4 6.5l4.5 4.5L4 15.5" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M10 6.5l4.5 4.5-4.5 4.5" stroke="#00d4ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M16 6.5l2.5 4.5-2.5 4.5" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    MLEbotics
                  </div>
                </th>
                <th scope="col" class="compare-col--scratch">From scratch</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>AI-ready architecture</td>
                <td class="compare-col--mle"><span class="check">✓</span> Built-in agents</td>
                <td class="compare-col--scratch"><span class="cross">✕</span> You build it</td>
              </tr>
              <tr>
                <td>Cross-platform support</td>
                <td class="compare-col--mle"><span class="check">✓</span> Flutter (5 platforms)</td>
                <td class="compare-col--scratch"><span class="warn">~</span> Multiple codebases</td>
              </tr>
              <tr>
                <td>Real-time sync</td>
                <td class="compare-col--mle"><span class="check">✓</span> Firebase included</td>
                <td class="compare-col--scratch"><span class="warn">~</span> Complex setup</td>
              </tr>
              <tr>
                <td>BLE / IoT integration</td>
                <td class="compare-col--mle"><span class="check">✓</span> Firmware + app</td>
                <td class="compare-col--scratch"><span class="cross">✕</span> Hardware expertise</td>
              </tr>
              <tr>
                <td>Open source</td>
                <td class="compare-col--mle"><span class="check">✓</span> GitHub public</td>
                <td class="compare-col--scratch"><span class="cross">✕</span> Start from zero</td>
              </tr>
              <tr>
                <td>Time to ship</td>
                <td class="compare-col--mle"><span class="check">✓</span> Days</td>
                <td class="compare-col--scratch"><span class="warn">~</span> Weeks / months</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ── Projects preview ─────────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <p class="tag">Featured projects</p>
        <h2 class="section__h2">Built at MLEbotics</h2>
        <div class="project-list">
          <a href="/projects#runcompanion" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Flutter · Firebase</span>
              <span class="project-status active">Active</span>
            </div>
            <h3>RunCompanion</h3>
            <p>AI-powered running coach. Tracks pace, plans sessions, and syncs with robotics training hardware.</p>
          </a>
          <a href="/projects#pacerpro" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Flutter · Dart</span>
              <span class="project-status active">Active</span>
            </div>
            <h3>PacerPro</h3>
            <p>Running pace calculator inside RunCompanion. Enter a goal time or distance and get instant splits, finish projections, and training zones.</p>
          </a>
          <a href="/projects#autoformfiller" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Chrome · Flask</span>
              <span class="project-status active">Active</span>
            </div>
            <h3>AutoFormFiller</h3>
            <p>Chrome extension + backend that automatically fills forms using AI — built for job applications and registrations.</p>
          </a>
          <a href="/projects#hey-girl" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Python · OpenAI</span>
              <span class="project-status active">Active</span>
            </div>
            <h3>Hey Girl</h3>
            <p>Voice AI assistant for Windows. Handles tasks, reads assignments, solves quizzes, and answers questions contextually.</p>
          </a>
          <a href="/projects#computer-use" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Anthropic · Desktop</span>
              <span class="project-status wip">In Progress</span>
            </div>
            <h3>Computer Use Agent</h3>
            <p>Anthropic-powered AI desktop agent that sees your screen and completes tasks like a human operator.</p>
          </a>
        </div>
        <div style="margin-top:2.5rem;text-align:center;">
          <a href="/projects" class="btn-outline" data-cta="projects_view_all" data-magnetic>View all projects &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ── CTA banner ────────────────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <div class="cta-banner">
          <h2>See it in action</h2>
          <p>Explore the live dashboard to track projects, robots, and workflows in real time.</p>
          <a href="https://console.mlebotics.com" class="btn-primary" data-cta="dashboard_open" data-magnetic>Open dashboard &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ── Testimonials ─────────────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <p class="tag">What people say</p>
        <h2 class="section__h2">Built for people who ship</h2>
        <div class="testimonials-grid">
          <blockquote class="testimonial-card card">
            <p class="testimonial-quote">"RunCompanion completely changed how I train. The AI coach adapts every session — it's like having a real trainer in my pocket."</p>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar" aria-hidden="true">JS</div>
              <div><strong class="testimonial-name">Jordan S.</strong><span class="testimonial-role">Marathon runner, Calgary</span></div>
            </footer>
          </blockquote>
          <blockquote class="testimonial-card card">
            <p class="testimonial-quote">"AutoFormFiller cut my job application time from 40 minutes to under 5. It reads my resume and fills everything intelligently."</p>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar" aria-hidden="true">MK</div>
              <div><strong class="testimonial-name">Mia K.</strong><span class="testimonial-role">Software engineer, Toronto</span></div>
            </footer>
          </blockquote>
          <blockquote class="testimonial-card card">
            <p class="testimonial-quote">"The level of engineering here is impressive. Modular, clean, and the Firebase integration is seamless. I've learned a lot just reading the code."</p>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar" aria-hidden="true">AR</div>
              <div><strong class="testimonial-name">Alex R.</strong><span class="testimonial-role">Full-stack developer</span></div>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- ── Tech stack ────────────────────────────────────────────────── -->
    <section class="section tech-section">
      <div class="container reveal">
        <p class="tech-label">Built with modern, proven tech</p>
        <div class="tech-strip">
          <span class="tech-badge">Flutter</span>
          <span class="tech-badge">Firebase</span>
          <span class="tech-badge">OpenAI</span>
          <span class="tech-badge">Anthropic</span>
          <span class="tech-badge">Python</span>
          <span class="tech-badge">TypeScript</span>
          <span class="tech-badge">Astro</span>
          <span class="tech-badge">Next.js</span>
          <span class="tech-badge">Tailwind CSS</span>
          <span class="tech-badge">Vercel</span>
          <span class="tech-badge">BLE / IoT</span>
          <span class="tech-badge">Dart</span>
        </div>
      </div>
    </section>

    <!-- ── Waitlist ──────────────────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <div class="waitlist-card">
          <p class="tag">Stay in the loop</p>
          <h2 class="waitlist-title">Get early access</h2>
          <p class="waitlist-sub">New tools, betas, and release notes — straight to your inbox. No spam, ever.</p>
          <form class="waitlist-form" id="waitlist-form" novalidate>
            <input
              type="email"
              name="email"
              class="waitlist-input"
              placeholder="you@example.com"
              autocomplete="email"
              required
              aria-label="Email address"
            />
            <button type="submit" class="btn-primary waitlist-btn">Join waitlist &rarr;</button>
          </form>
          <p class="waitlist-confirm" id="waitlist-confirm" hidden>
            ✓ You're on the list! We'll be in touch.
          </p>
          <p class="waitlist-note">Joined by builders in 🇨🇦 🇺🇸 🇬🇧 🇦🇺 🇩🇪 and more.</p>
        </div>
      </div>
    </section>

    <!-- ── Community Chat ─────────────────────────────────────────── -->
    <section class="section">
      <div class="container reveal">
        <div class="community-card">
          <div class="community-card__left">
            <p class="tag">Community</p>
            <h2 class="section__h2" style="margin-bottom:.75rem;">Build with us</h2>
            <p class="community-desc">Ask questions, share what you're building, show off projects, and connect with other MLEbotics builders — all in one place.</p>
