<script>
  const track = (name: string, params: Record<string, string | number> = {}) => {
    ;(window as any).mleTrack?.(name, params)
  }

  // Typewriter
  const phrases = ['Remove friction.', 'Build AI agents.', 'Ship robotics tools.', 'Automate everything.', 'Remove friction.']
  const el = document.getElementById('typewriter')
  const heroSub = document.getElementById('hero-sub')
  const heroPrimaryCta = document.getElementById('hero-cta-primary')
  let phraseIdx = 0
  let charIdx = 0
  let deleting = false
  let pauseFrames = 0
  const lowMotionMobile = window.matchMedia('(max-width: 860px)').matches
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  // Lightweight A/B experiment for conversion tuning.
  const heroVariant =
    (window as any).mleAssignExperiment?.('hero-v2', ['control', 'velocity']) ||
    'control'

  if (heroVariant === 'velocity') {
    if (heroSub) {
      heroSub.textContent = 'Launch faster with production-grade AI, automation, and robotics systems that feel intentional from day one.'
    }
    if (heroPrimaryCta) {
      heroPrimaryCta.textContent = 'Start with case studies'
    }
  }

  track('hero_variant_seen', { variant: heroVariant })

  if (lowMotionMobile || reducedMotion) {
    if (el) el.textContent = phrases[0]
  } else {
    type()
  }

  function type() {
    if (!el) return
    const current = phrases[phraseIdx]
    if (!deleting && charIdx <= current.length) {
      el.textContent = current.slice(0, charIdx++)
    } else if (deleting && charIdx >= 0) {
      el.textContent = current.slice(0, charIdx--)
    }
    if (!deleting && charIdx > current.length) {
      if (pauseFrames++ < 55) { requestAnimationFrame(() => setTimeout(type, 16)); return }
      pauseFrames = 0
      deleting = true
    }
    if (deleting && charIdx < 0) {
      deleting = false
      charIdx = 0
      phraseIdx = (phraseIdx + 1) % phrases.length
    }
    const delay = deleting ? 38 : 68
    setTimeout(type, delay)
  }

  // Animated counters
  function animateCounter(el: Element) {
    const target = parseInt((el as HTMLElement).dataset.target || '0', 10)
    let start = 0
    const duration = 1400
    const step = (timestamp: number, startTime: number) => {
      const progress = Math.min((timestamp - startTime) / duration, 1)
      const eased = 1 - Math.pow(1 - progress, 3)
      el.textContent = String(Math.floor(eased * target))
      if (progress < 1) requestAnimationFrame((t) => step(t, startTime))
      else el.textContent = String(target)
    }
    requestAnimationFrame((t) => step(t, t))
  }

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        animateCounter(e.target)
        counterObserver.unobserve(e.target)
      }
    })
  }, { threshold: 0.5 })
  document.querySelectorAll('.stat-num').forEach((el) => counterObserver.observe(el))

  // Interactive control room mode switch
  const shell = document.getElementById('command-shell') as HTMLElement | null
  const modeButtons = document.querySelectorAll('.command-mode-btn')
  const commandKicker = document.getElementById('command-kicker')
  const commandTitle = document.getElementById('command-title')
  const commandCopy = document.getElementById('command-copy')
  const metricA = document.getElementById('metric-a')
  const metricB = document.getElementById('metric-b')
  const metricC = document.getElementById('metric-c')
  const signalQueue = document.getElementById('signal-queue')
  const signalLatency = document.getElementById('signal-latency')
  const signalSync = document.getElementById('signal-sync')

  const modeContent = {
    build: {
      kicker: 'Build mode',
      title: 'Design, prototype, and ship with product-grade speed.',
      copy: 'From architecture maps to deploy-ready modules, every phase stays connected so your team can move from concept to production without handoff friction.',
      a: '7 days',
      b: '99.4%',
      c: 'Production-ready',
      queue: '26 active jobs',
      latency: '312ms',
      sync: 'Stable',
    },
    operate: {
      kicker: 'Operate mode',
      title: 'Monitor every workflow in real time with human-level clarity.',
      copy: 'Unified telemetry and event pipelines show what is running, what is blocked, and what should be optimized next across your entire stack.',
      a: '24/7 visibility',
      b: '99.8%',
      c: 'Auto-recovery',
      queue: '42 active jobs',
      latency: '268ms',
      sync: 'Realtime',
    },
    scale: {
      kicker: 'Scale mode',
      title: 'Expand across products, teams, and hardware without chaos.',
      copy: 'Modular architecture keeps integrations clean, deployment repeatable, and every new feature aligned with long-term platform reliability.',
      a: '5 platforms',
      b: '98.9%',
      c: 'Multi-region ready',
      queue: '71 active jobs',
      latency: '341ms',
      sync: 'Global replication',
    },
  } as const

  function applyMode(mode: keyof typeof modeContent) {
    const content = modeContent[mode]
    shell?.setAttribute('data-mode', mode)
    if (commandKicker) commandKicker.textContent = content.kicker
    if (commandTitle) commandTitle.textContent = content.title
    if (commandCopy) commandCopy.textContent = content.copy
    if (metricA) metricA.textContent = content.a
    if (metricB) metricB.textContent = content.b
    if (metricC) metricC.textContent = content.c
    if (signalQueue) signalQueue.textContent = content.queue
    if (signalLatency) signalLatency.textContent = content.latency
    if (signalSync) signalSync.textContent = content.sync

    modeButtons.forEach((btn) => {
      const current = (btn as HTMLElement).dataset.mode === mode
      btn.classList.toggle('active', current)
      btn.setAttribute('aria-pressed', String(current))
    })
  }

  modeButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = (btn as HTMLElement).dataset.mode as keyof typeof modeContent
      if (!mode || !modeContent[mode]) return
      applyMode(mode)
      track('control_room_mode_change', { mode })
    })
  })

  // Waitlist form — client-side only (stores to localStorage as a stub)
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null
  const confirm = document.getElementById('waitlist-confirm') as HTMLElement | null
  form?.addEventListener('submit', (e) => {
    e.preventDefault()
    const data = new FormData(form)
    const email = (data.get('email') as string)?.trim()
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return
    form.style.display = 'none'
    if (confirm) confirm.hidden = false
    track('waitlist_signup', { source: 'homepage_waitlist', variant: heroVariant || 'control' })
  })

  // 3D card tilt effect
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  if (!prefersReduced && window.matchMedia('(hover: hover)').matches) {
    document.querySelectorAll('.tilt-card').forEach((el) => {
      const card = el as HTMLElement
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect()
        const x = (e.clientX - rect.left) / rect.width - 0.5
        const y = (e.clientY - rect.top) / rect.height - 0.5
        card.style.transform = `perspective(900px) rotateY(${x * 7}deg) rotateX(${-y * 7}deg) translateY(-2px) scale(1.01)`
        card.style.transition = 'transform .08s ease-out, box-shadow .08s, border-color .08s'
      })
      card.addEventListener('mouseleave', () => {
        card.style.transform = 'perspective(900px) rotateY(0deg) rotateX(0deg) translateY(0) scale(1)'
        card.style.transition = 'transform .4s cubic-bezier(.22,1,.36,1), box-shadow .22s, border-color .22s'
      })
    })

  }

  const depthMarks = [20, 50, 80]
  const seenDepth = new Set<number>()
  window.addEventListener('scroll', () => {
    const total = document.documentElement.scrollHeight - window.innerHeight
    if (total <= 0) return
    const pct = Math.round((window.scrollY / total) * 100)
    depthMarks.forEach((mark) => {
      if (pct >= mark && !seenDepth.has(mark)) {
        seenDepth.add(mark)
        track('scroll_depth', { depth_percent: mark, page: 'home' })
      }
    })
  }, { passive: true })
</script>


